  </div>
  <div class="w-full flex gap-6 px-4 md:px-6 py-4 md:py-6 relative items-start wrapper">
   <!-- Mobile Menu Toggle --> <button id="mobileToggle" class="mobile-toggle fixed top-4 left-4 z-50 bg-white p-3 rounded-xl shadow-lg items-center justify-center" aria-label="Toggle menu"> <i data-lucide="menu" class="w-6 h-6 text-slate-700"></i> </button> <!-- Mobile Overlay -->
   <div id="mobileOverlay" class="mobile-overlay fixed inset-0 bg-black/30 z-40 hidden"></div><!-- Sidebar -->
   <aside id="sidebar" class="sidebar p-6 flex flex-col gap-2 self-stretch" style="padding-bottom: 24px;">
