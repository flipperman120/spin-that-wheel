      <label class="block text-sm font-medium mb-3" data-template-id="repeat-label" style="color: rgb(48, 57, 113); font-weight: 700; font-style: normal; font-size: 13px;">Repeat on</label>
      <div class="flex flex-wrap gap-2">
       <label class="day-btn flex items-center justify-center w-11 h-11 border-2 border-gray-200 cursor-pointer transition-all" style="border-radius: 8px; color: rgb(48, 57, 113);" data-template-id="day-btn-sun"> <input type="checkbox" name="days" value="sun" class="sr-only"> <span class="text-sm font-medium">S</span> </label> <label class="day-btn flex items-center justify-center w-11 h-11 border-2 border-gray-200 cursor-pointer transition-all" style="border-radius: 8px; color: rgb(48, 57, 113);" data-template-id="day-btn-mon"> <input type="checkbox" name="days" value="mon" class="sr-only"> <span class="text-sm font-medium">M</span> </label> <label class="day-btn flex items-center justify-center w-11 h-11 border-2 border-gray-200 cursor-pointer transition-all" style="border-radius: 8px; color: rgb(48, 57, 113);" data-template-id="day-btn-tue"> <input type="checkbox" name="days" value="tue" class="sr-only"> <span class="text-sm font-medium">T</span> </label> <label class="day-btn flex items-center justify-center w-11 h-11 border-2 border-gray-200 cursor-pointer transition-all" style="border-radius: 8px; color: rgb(48, 57, 113);" data-template-id="day-btn-wed"> <input type="checkbox" name="days" value="wed" class="sr-only"> <span class="text-sm font-medium">W</span> </label> <label class="day-btn flex items-center justify-center w-11 h-11 border-2 border-gray-200 cursor-pointer transition-all" style="border-radius: 8px; color: rgb(48, 57, 113);" data-template-id="day-btn-thu"> <input type="checkbox" name="days" value="thu" class="sr-only"> <span class="text-sm font-medium">T</span> </label> <label class="day-btn flex items-center justify-center w-11 h-11 border-2 border-gray-200 cursor-pointer transition-all" style="border-radius: 8px; color: rgb(48, 57, 113);" data-template-id="day-btn-fri"> <input type="checkbox" name="days" value="fri" class="sr-only"> <span class="text-sm font-medium">F</span> </label> <label class="day-btn flex items-center justify-center w-11 h-11 border-2 border-gray-200 cursor-pointer transition-all" style="border-radius: 8px; color: rgb(48, 57, 113);" data-template-id="day-btn-sat"> <input type="checkbox" name="days" value="sat" class="sr-only"> <span class="text-sm font-medium">S</span> </label>
      </div>
      <p id="daysError" class="text-sm text-red-500 mt-2 hidden" data-template-id="days-error" style="color: rgb(239, 68, 68); font-weight: 400; font-style: normal; font-size: 16px;">Please select at least one day</p>
     </div>
     <div class="flex gap-3 pt-2">
      <button type="button" id="cancelBtn" class="flex-1 py-3 px-4 border-2 border-gray-200 font-medium hover:bg-gray-50 transition-colors" style="border-radius: 9999px; color: rgb(48, 57, 113); font-weight: 700; font-style: normal; font-size: 13px;" data-template-id="modal-cancel-btn">Cancel</button> <button type="submit" id="saveBtn" class="btn-primary flex-1 py-3 px-4 font-medium" data-template-id="modal-save-btn" style="background: rgb(32, 81, 130); color: rgb(255, 255, 255); font-family: Okomito; font-weight: 700; font-style: normal; font-size: 13px;">Save Habit</button>
     </div>
    </form>
   </div>
  </div><!-- Delete Confirmation Modal -->
  <div id="deleteModal" class="modal-overlay fixed inset-0 bg-black/40 flex items-center justify-center z-50 hidden p-4">
   <div class="modal-content p-6 md:p-8 w-full max-w-sm shadow-md" style="border-radius: 12px; background: #FFFFFF; border: 1px solid #E5E7EB;">
    <div class="w-16 h-16 flex items-center justify-center mx-auto mb-4" style="background-color: #205182; border-radius: 9999px;">
     <i data-lucide="trash-2" class="w-8 h-8 text-white"></i>
    </div>
    <h2 class="text-xl font-bold mb-2 text-center" data-template-id="delete-title" style="color: rgb(48, 57, 113); font-family: Okomito; font-weight: 700; font-style: normal; font-size: 18px;">Delete Habit?</h2>
    <p class="text-gray-500 mb-6 text-center" data-template-id="delete-message" style="color: rgb(113, 128, 150); font-weight: 400; font-style: normal; font-size: 16px;">This will remove the habit and all its completion data. This action cannot be undone.</p>
    <div class="flex gap-3">
     <button id="cancelDelete" class="flex-1 py-3 px-4 border-2 border-gray-200 font-medium" style="border-radius: 9999px; color: rgb(48, 57, 113); font-weight: 700; font-style: normal; font-size: 13px;" data-template-id="delete-cancel-btn">Cancel</button> <button id="confirmDelete" class="btn-primary flex-1 py-3 px-4 font-medium" style="border-radius: 9999px; background: rgb(32, 81, 130); color: rgb(255, 255, 255); font-weight: 700; font-style: normal; font-size: 13px;" data-template-id="delete-confirm-btn">Delete</button>
    </div>
   </div>
  </div>
  <script src="/_sdk/editing_sdk.js"></script>
  <script>
        // State
        let habits = [];
        let selectedDate = new Date();
        let viewMonth = new Date();
        let editingHabit = null;
        let deletingHabit = null;
        let isLoading = false;
        
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        
        const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
        const dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
        const dayKeys = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'];
        
        // DOM Elements
        const calendarGrid = document.getElementById('calendarGrid');
        const calendarMonth = document.getElementById('calendarMonth');
        const prevMonthBtn = document.getElementById('prevMonth');
        const nextMonthBtn = document.getElementById('nextMonth');
        const returnTodayBtn = document.getElementById('returnToday');
        const addHabitBtn = document.getElementById('addHabitBtn');
        const habitModal = document.getElementById('habitModal');
        const habitForm = document.getElementById('habitForm');
        const habitNameInput = document.getElementById('habitName');
        const charCount = document.getElementById('charCount');
        const cancelBtn = document.getElementById('cancelBtn');
        const saveBtn = document.getElementById('saveBtn');
        const modalTitle = document.getElementById('modalTitle');
        const deleteModal = document.getElementById('deleteModal');
        const cancelDelete = document.getElementById('cancelDelete');
        const confirmDelete = document.getElementById('confirmDelete');
        const progressBar = document.getElementById('progressBar');
        const progressText = document.getElementById('progressText');
        const selectedDateDisplay = document.getElementById('selectedDateDisplay');
        const mobileToggle = document.getElementById('mobileToggle');
        const mobileOverlay = document.getElementById('mobileOverlay');
        const sidebar = document.getElementById('sidebar');
        
        // Mobile sidebar toggle removed - calendar always visible on mobile
        
        const categoryBtns = document.querySelectorAll('.category-btn');
        const dayBtns = document.querySelectorAll('.day-btn');
        
        let selectedCategory = 'Morning';
        
        // Load habits from localStorage
        function loadHabits() {
            try {
                const stored = localStorage.getItem('habits');
                return stored ? JSON.parse(stored) : [];
            } catch {
                return [];
            }
        }
        
        // Save habits to localStorage
        function saveHabits() {
            localStorage.setItem('habits', JSON.stringify(habits));
        }
        
        // Initialize
        function init() {
            habits = loadHabits();
            selectedDate = new Date(today);
            viewMonth = new Date(today);
            
            setupEventListeners();
            setupDragAndDrop();
            renderCalendar();
            renderHabits();
            updateProgress();
            lucide.createIcons();
        }
        
        function setupEventListeners() {
            prevMonthBtn.addEventListener('click', () => {
                viewMonth.setMonth(viewMonth.getMonth() - 1);
                renderCalendar();
            });
            
            nextMonthBtn.addEventListener('click', () => {
                viewMonth.setMonth(viewMonth.getMonth() + 1);
                renderCalendar();
            });
            
            returnTodayBtn.addEventListener('click', () => {
                selectedDate = new Date(today);
                viewMonth = new Date(today);
                renderCalendar();
                renderHabits();
                updateProgress();
            });
            
            addHabitBtn.addEventListener('click', () => openModal());
            cancelBtn.addEventListener('click', closeModal);
            habitForm.addEventListener('submit', handleSaveHabit);
            
            habitNameInput.addEventListener('input', () => {
                charCount.textContent = `${habitNameInput.value.length}/30`;
            });
            
            categoryBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    selectedCategory = btn.dataset.category;
                    updateCategoryButtons();
                    checkCategoryLimit();
                });
            });
            
            dayBtns.forEach(btn => {
                const checkbox = btn.querySelector('input');
                checkbox.addEventListener('change', () => {
                    updateDayButtons();
                });
            });
            
            cancelDelete.addEventListener('click', closeDeleteModal);
            confirmDelete.addEventListener('click', handleConfirmDelete);
            
            habitModal.addEventListener('click', (e) => {
                if (e.target === habitModal) closeModal();
            });
            
            deleteModal.addEventListener('click', (e) => {
                if (e.target === deleteModal) closeDeleteModal();
            });
        }
        
        function renderCalendar() {
            calendarGrid.innerHTML = '';
            calendarMonth.textContent = `${monthNames[viewMonth.getMonth()]} ${viewMonth.getFullYear()}`;
            
            const year = viewMonth.getFullYear();
            const month = viewMonth.getMonth();
            const firstDay = new Date(year, month, 1).getDay();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            
            // Empty cells for days before first of month
            for (let i = 0; i < firstDay; i++) {
                const emptyCell = document.createElement('div');
                emptyCell.className = 'calendar-day empty';
                calendarGrid.appendChild(emptyCell);
            }
            
            // Days of current month
            for (let day = 1; day <= daysInMonth; day++) {
                const date = new Date(year, month, day);
                date.setHours(0, 0, 0, 0);
                
                const dayCell = document.createElement('button');
                dayCell.className = 'calendar-day flex items-center justify-center text-sm font-medium';
                dayCell.textContent = day;
                dayCell.setAttribute('aria-label', `${monthNames[month]} ${day}, ${year}`);
                
                const isToday = date.getTime() === today.getTime();
                const isSelected = date.getTime() === selectedDate.getTime();
                
                if (isToday) {
                    dayCell.classList.add('today');
                } else if (isSelected) {
                    dayCell.classList.add('selected');
                }
                
                dayCell.addEventListener('click', () => {
                    selectedDate = new Date(date);
                    renderCalendar();
                    renderHabits();
                    updateProgress();
                    
                    // Close mobile sidebar after selection
                    sidebar.classList.remove('open');
                    mobileOverlay.classList.add('hidden');
                });
                
                calendarGrid.appendChild(dayCell);
            }
            
            updateSelectedDateDisplay();
        }
        
        function updateSelectedDateDisplay() {
            const options = { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' };
            selectedDateDisplay.textContent = selectedDate.toLocaleDateString('en-US', options);
        }
        
        function getHabitsForDate(date) {
            const dayKey = dayKeys[date.getDay()];
            const dateStr = date.toISOString().split('T')[0];
            
            return habits.filter(habit => {
                const repeatKey = `repeatable_${dayKey}`;
                // Strict equality check: only habits with explicitly true values appear
                if (habit[repeatKey] !== true) return false;
                
                const createdDate = new Date(habit.date_created);
                createdDate.setHours(0, 0, 0, 0);
                return date >= createdDate;
            }).sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0));
        }
        
        function isHabitCompletedOnDate(habit, date) {
            const dateStr = date.toISOString().split('T')[0];
            try {
                const completions = JSON.parse(habit.completions || '{}');
                return completions[dateStr] === true;
            } catch {
                return false;
            }
        }
        
        function renderHabits() {
            const morningContainer = document.getElementById('morningHabits');
            const noonContainer = document.getElementById('noonHabits');
            const eveningContainer = document.getElementById('eveningHabits');
            const morningEmpty = document.getElementById('morningEmpty');
            const noonEmpty = document.getElementById('noonEmpty');
            const eveningEmpty = document.getElementById('eveningEmpty');
            
            morningContainer.innerHTML = '';
            noonContainer.innerHTML = '';
            eveningContainer.innerHTML = '';
            
            const dayHabits = getHabitsForDate(selectedDate);
            
            // Filter habits by category AND by day match
            const morningHabits = dayHabits.filter(h => h.category === 'Morning');
            const noonHabits = dayHabits.filter(h => h.category === 'Noon');
            const eveningHabits = dayHabits.filter(h => h.category === 'Evening');
            
            morningHabits.forEach(h => morningContainer.appendChild(createHabitCard(h)));
            noonHabits.forEach(h => noonContainer.appendChild(createHabitCard(h)));
            eveningHabits.forEach(h => eveningContainer.appendChild(createHabitCard(h)));
            
            morningEmpty.classList.toggle('hidden', morningHabits.length > 0);
            noonEmpty.classList.toggle('hidden', noonHabits.length > 0);
            eveningEmpty.classList.toggle('hidden', eveningHabits.length > 0);
            
            lucide.createIcons();
        }
        
        function createHabitCard(habit) {
            const card = document.createElement('div');
            card.className = 'habit-card glass p-4 flex items-center gap-4';
            card.dataset.habitId = habit.habit_id;
            card.draggable = true;
            
            const isCompleted = isHabitCompletedOnDate(habit, selectedDate);
            const isToday = selectedDate.getTime() === today.getTime();
            
            const checkbox = document.createElement('input');
            checkbox.type = 'checkbox';
            checkbox.className = 'habit-checkbox flex-shrink-0';
            checkbox.checked = isCompleted;
            checkbox.disabled = !isToday;
            checkbox.id = `habit-${habit.habit_id}`;
            checkbox.setAttribute('aria-label', `Mark ${habit.name} as ${isCompleted ? 'incomplete' : 'complete'}`);
            
            if (isToday) {
                checkbox.addEventListener('change', () => handleToggleHabit(habit, checkbox.checked));
            }
            
            const content = document.createElement('div');
            content.className = 'flex-1 min-w-0';
            
            const nameRow = document.createElement('div');
            nameRow.className = 'flex items-center gap-2 flex-wrap';
            
            const name = document.createElement('label');
            name.className = 'font-medium truncate cursor-pointer';
            name.htmlFor = checkbox.id;
            name.textContent = habit.name;
            name.title = habit.name.length > 30 ? habit.name : '';
            
            const categoryClass = habit.category === 'Morning' ? 'category-morning' : 
                                  habit.category === 'Noon' ? 'category-noon' : 'category-evening';
            const category = document.createElement('span');
            category.className = `category-tag ${categoryClass}`;
            category.textContent = habit.category;
            
            nameRow.appendChild(name);
            nameRow.appendChild(category);
            content.appendChild(nameRow);
            
            const streak = document.createElement('div');
            streak.className = 'flex items-center gap-1 mt-1';
            streak.innerHTML = `<i data-lucide="flame" class="w-4 h-4" style="color: #E67E22;"></i>`;
            const streakNum = document.createElement('span');
            streakNum.className = 'text-sm font-medium text-gray-500';
            streakNum.textContent = `${habit.current_streak || 0} day streak`;
            streak.appendChild(streakNum);
            content.appendChild(streak);
            
            const dragHandle = document.createElement('button');
            dragHandle.className = 'icon-btn flex items-center justify-center cursor-grab active:cursor-grabbing';
            dragHandle.innerHTML = '<i data-lucide="grip-vertical" class="w-5 h-5" style="color: #6B7280;"></i>';
            dragHandle.setAttribute('aria-label', 'Drag to reorder');
            dragHandle.setAttribute('type', 'button');
            dragHandle.dataset.dragHandle = 'true';
            
            const actions = document.createElement('div');
            actions.className = 'flex items-center gap-2 flex-shrink-0';
            
            const editBtn = document.createElement('button');
            editBtn.className = 'icon-btn flex items-center justify-center';
            editBtn.innerHTML = '<i data-lucide="pencil" class="w-5 h-5" style="color: #6B7280;"></i>';
            editBtn.setAttribute('aria-label', `Edit ${habit.name}`);
            editBtn.addEventListener('click', () => openModal(habit));
            
            const deleteBtn = document.createElement('button');
            deleteBtn.className = 'icon-btn flex items-center justify-center';
            deleteBtn.innerHTML = '<i data-lucide="trash-2" class="w-5 h-5" style="color: #6B7280;"></i>';
            deleteBtn.setAttribute('aria-label', `Delete ${habit.name}`);
            deleteBtn.addEventListener('click', () => openDeleteModal(habit));
            
            actions.appendChild(editBtn);
            actions.appendChild(deleteBtn);
            
            card.appendChild(checkbox);
            card.appendChild(content);
            card.appendChild(dragHandle);
            card.appendChild(actions);
            
            return card;
        }
        
        function getHabitsForCategory(category) {
            const sortedHabits = habits.filter(h => h.category === category);
            sortedHabits.sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0));
            return sortedHabits;
        }
        
        function setupDragAndDrop() {
            const habitContainers = {
                'Morning': document.getElementById('morningHabits'),
                'Noon': document.getElementById('noonHabits'),
                'Evening': document.getElementById('eveningHabits')
            };
            
            const sectionDropZones = {
                'Morning': document.getElementById('morningSection'),
                'Noon': document.getElementById('noonSection'),
                'Evening': document.getElementById('eveningSection')
            };
            
            let draggedHabit = null;
            let sourceCategory = null;
            let draggedElement = null;
            
            document.addEventListener('dragstart', (e) => {
                const card = e.target.closest('[data-habit-id]');
                if (!card) return;
                
                draggedElement = card;
                draggedHabit = habits.find(h => h.habit_id === card.dataset.habitId);
                sourceCategory = draggedHabit?.category;
                
                e.dataTransfer.effectAllowed = 'move';
                card.style.opacity = '0.5';
            });
            
            document.addEventListener('dragend', (e) => {
                if (draggedElement) {
                    draggedElement.style.opacity = '1';
                }
                
                Object.values(habitContainers).forEach(container => {
                    container.classList.remove('drag-over');
                });
                
                draggedElement = null;
                draggedHabit = null;
                sourceCategory = null;
            });
            
            // Set up drop zones on both habit containers and section containers
            Object.entries(habitContainers).forEach(([category, container]) => {
                setupDropZone(container, category, habitContainers, sectionDropZones);
            });
            
            // Set up drop zones on section containers to enable cross-category dragging even when sections are empty
            Object.entries(sectionDropZones).forEach(([category, section]) => {
                section.addEventListener('dragover', (e) => {
                    if (!draggedHabit) return;
                    e.preventDefault();
                    e.dataTransfer.dropEffect = 'move';
                    
                    // Add animated drop indicator to section
                    section.classList.add('drag-over-active');
                    
                    // Highlight the habit list container, not the section
                    const habitList = section.querySelector('.habit-list');
                    if (habitList) {
                        habitList.classList.add('drag-over');
                    }
                });
                
                section.addEventListener('dragleave', (e) => {
                    // Only remove highlight if leaving the section entirely
                    if (!section.contains(e.relatedTarget)) {
                        section.classList.remove('drag-over-active');
                        const habitList = section.querySelector('.habit-list');
                        if (habitList) {
                            habitList.classList.remove('drag-over');
                        }
                    }
                });
                
                section.addEventListener('drop', (e) => {
                    e.preventDefault();
                    
                    section.classList.remove('drag-over-active');
                    const habitList = section.querySelector('.habit-list');
                    if (habitList) {
                        habitList.classList.remove('drag-over');
                    }
                    
                    if (!draggedHabit) return;
                    
                    const destinationCategory = category;
                    const isCategoryChange = sourceCategory !== destinationCategory;
                    
                    // Check 5-habit limit when moving to a new category
                    if (isCategoryChange) {
                        const destCategoryCount = habits.filter(h => h.category === destinationCategory).length;
                        if (destCategoryCount >= 5) {
                            return;
                        }
                    }
                    
                    // Calculate new sort order based on drop position in the habit list
                    const habitListContainer = section.querySelector('.habit-list');
                    const cards = habitListContainer ? [...habitListContainer.querySelectorAll('[data-habit-id]')] : [];
                    let targetIndex = cards.length;
                    
                    for (let i = 0; i < cards.length; i++) {
                        const rect = cards[i].getBoundingClientRect();
                        if (e.clientY < rect.top + rect.height / 2) {
                            targetIndex = i;
                            break;
                        }
                    }
                    
                    // Update habit: change category if needed and update sort_order
                    draggedHabit.category = destinationCategory;
                    draggedHabit.sort_order = targetIndex;
                    
                    // Re-index all habits in destination category
                    const destHabits = habits
                        .filter(h => h.category === destinationCategory && h.habit_id !== draggedHabit.habit_id)
                        .sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0));
                    
                    destHabits.forEach((h, idx) => {
                        const newIdx = idx < targetIndex ? idx : idx + 1;
                        h.sort_order = newIdx;
                    });
                    
                    // If moved between categories, re-index source category too
                    if (isCategoryChange && sourceCategory) {
                        const sourceHabits = habits
                            .filter(h => h.category === sourceCategory && h.habit_id !== draggedHabit.habit_id)
                            .sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0));
                        
                        sourceHabits.forEach((h, idx) => {
                            h.sort_order = idx;
                        });
                    }
                    
                    saveHabits();
                    renderHabits();
                });
            });
            
            function setupDropZone(dropTarget, category, containers, sections) {
                dropTarget.addEventListener('dragover', (e) => {
                    if (!draggedHabit) return;
                    e.preventDefault();
                    e.dataTransfer.dropEffect = 'move';
                    
                    dropTarget.classList.add('drag-over');
                });
                
                dropTarget.addEventListener('dragleave', (e) => {
                    if (e.target === dropTarget || !dropTarget.contains(e.relatedTarget)) {
                        dropTarget.classList.remove('drag-over');
                    }
                });
                
                dropTarget.addEventListener('drop', (e) => {
                    e.preventDefault();
                    dropTarget.classList.remove('drag-over');
                    
                    if (!draggedHabit) return;
                    
                    const destinationCategory = category;
                    const isCategoryChange = sourceCategory !== destinationCategory;
                    
                    // Check 5-habit limit when moving to a new category
                    if (isCategoryChange) {
                        const destCategoryCount = habits.filter(h => h.category === destinationCategory).length;
                        if (destCategoryCount >= 5) {
                            return;
                        }
                    }
                    
                    // Calculate new sort order based on drop position
                    const cards = [...dropTarget.querySelectorAll('[data-habit-id]')];
                    let targetIndex = cards.length;
                    
                    for (let i = 0; i < cards.length; i++) {
                        const rect = cards[i].getBoundingClientRect();
                        if (e.clientY < rect.top + rect.height / 2) {
                            targetIndex = i;
                            break;
                        }
                    }
                    
                    // Update habit: change category if needed and update sort_order
                    draggedHabit.category = destinationCategory;
                    draggedHabit.sort_order = targetIndex;
                    
                    // Re-index all habits in destination category
                    const destHabits = habits
                        .filter(h => h.category === destinationCategory && h.habit_id !== draggedHabit.habit_id)
                        .sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0));
                    
                    destHabits.forEach((h, idx) => {
                        const newIdx = idx < targetIndex ? idx : idx + 1;
                        h.sort_order = newIdx;
                    });
                    
                    // If moved between categories, re-index source category too
                    if (isCategoryChange && sourceCategory) {
                        const sourceHabits = habits
                            .filter(h => h.category === sourceCategory && h.habit_id !== draggedHabit.habit_id)
                            .sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0));
                        
                        sourceHabits.forEach((h, idx) => {
                            h.sort_order = idx;
                        });
                    }
                    
                    saveHabits();
                    renderHabits();
