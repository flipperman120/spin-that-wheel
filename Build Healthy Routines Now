        <h2 class="text-lg font-semibold" style="color: rgb(32, 81, 130); font-family: Okomito; font-weight: 700; font-style: normal; font-size: 16px;" data-template-id="noon-heading">Noon</h2>
       </div>
       <div id="noonHabits" class="habit-list space-y-4"></div>
       <p id="noonEmpty" data-template-id="noon-empty" class="text-gray-400 text-center py-6 italic hidden" style="color: rgb(113, 128, 150); font-weight: 400; font-style: italic; font-size: 13px;">There are no Noon habits yet. Add a habit to start tracking.</p>
      </section>
      <div class="section-divider"></div><!-- Evening Section -->
      <section id="eveningSection" class="drop-zone" data-category="Evening">
       <div class="flex items-center gap-3 mb-4">
        <i data-lucide="moon" class="w-5 h-5" style="color: var(--mid-blue);"></i>
        <h2 class="text-lg font-semibold" style="color: rgb(32, 81, 130); font-family: Okomito; font-weight: 700; font-style: normal; font-size: 16px;" data-template-id="evening-heading">Evening</h2>
       </div>
       <div id="eveningHabits" class="habit-list space-y-4"></div>
       <p id="eveningEmpty" data-template-id="evening-empty" class="text-gray-400 text-center py-6 italic hidden" style="color: rgb(113, 128, 150); font-weight: 400; font-style: italic; font-size: 13px;">There are no Evening habits yet. Add a habit to start tracking.</p>
      </section>
     </div>
    </div>
   </main><!-- Motivational Text Footer - Mobile only -->
   <div class="md:hidden w-full max-w-390 mx-auto px-4 pt-6 text-center">
    <p data-template-id="motivational-text-mobile" class="text-sm font-medium" style="color: rgb(255, 255, 255); font-weight: 400; font-style: normal; font-size: 18px;">Every small step counts. 
Track your progress with confidence.</p>
   </div>
  </div><!-- Add/Edit Habit Modal -->
  <div id="habitModal" class="modal-overlay fixed inset-0 bg-black/40 flex items-center justify-center z-50 hidden p-4">
   <div class="modal-content p-6 md:p-8 w-full max-w-md shadow-md" style="border-radius: 12px; background: #FFFFFF; border: 1px solid #E5E7EB;">
    <h2 id="modalTitle" class="text-xl font-bold mb-6" style="font-family: 'Radio Canada', sans-serif;">Add New Habit</h2>
    <form id="habitForm" class="space-y-6">
     <div>
      <label for="habitName" class="block text-sm font-medium mb-2" data-template-id="habit-name-label" style="color: rgb(48, 57, 113); font-weight: 700; font-style: normal; font-size: 13px;">Habit Name</label> <input type="text" id="habitName" maxlength="30" class="w-full px-4 py-3 border-2 border-gray-200 focus:outline-none transition-colors" style="border-radius: 8px; --tw-ring-color: #6BA3D6;" onfocus="this.style.borderColor='#6BA3D6'" onblur="this.style.borderColor='#e5e7eb'" placeholder="e.g., Morning meditation">
