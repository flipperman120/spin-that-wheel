    <div class="calendar-section glass p-6" style="margin-top: -24px; position: relative; overflow: hidden; border-radius: 10px; background: linear-gradient(rgb(211, 227, 252), rgb(187, 214, 248), rgb(207, 223, 250));" data-template-id="sidebar-gradient">
     <div class="flex items-center justify-between mb-4">
