            editingHabit = null;
            document.getElementById('daysError').classList.add('hidden');
            document.getElementById('categoryLimitMsg').classList.add('hidden');
        }
        
        function updateCategoryButtons() {
            categoryBtns.forEach(btn => {
                const isSelected = btn.dataset.category === selectedCategory;
                btn.classList.toggle('border-blue-400', isSelected);
                btn.style.backgroundColor = isSelected ? 'var(--accent-blue)' : '';
                btn.style.color = isSelected ? 'white' : '';
            });
        }
        
        function updateDayButtons() {
            dayBtns.forEach(btn => {
                const checkbox = btn.querySelector('input');
                btn.classList.toggle('border-blue-400', checkbox.checked);
                btn.classList.toggle('active', checkbox.checked);
                btn.style.backgroundColor = checkbox.checked ? 'var(--accent-blue)' : '';
            });
        }
        
        function checkCategoryLimit() {
            const categoryLimitMsg = document.getElementById('categoryLimitMsg');
            const categoryCount = habits.filter(h => h.category === selectedCategory).length;
            const isEditing = editingHabit && editingHabit.category === selectedCategory;
            const limit = isEditing ? 5 : 4;
            
            if (categoryCount >= 5 && !isEditing) {
                categoryLimitMsg.textContent = `You can track up to 5 ${selectedCategory} habits at a time.`;
                categoryLimitMsg.classList.remove('hidden');
                saveBtn.disabled = true;
            } else {
                categoryLimitMsg.classList.add('hidden');
                saveBtn.disabled = false;
            }
        }
        
        function handleSaveHabit(e) {
            e.preventDefault();
            
            const name = habitNameInput.value.trim();
            if (!name) {
                habitNameInput.focus();
                return;
            }
            
            // Explicitly map each checkbox state to the corresponding repeatable_* property
            // Ensure unselected days are set to false, not undefined or omitted
            const dayProperties = {};
            dayKeys.forEach(dayKey => {
                const checkbox = habitForm.querySelector(`input[name="days"][value="${dayKey}"]`);
                dayProperties[`repeatable_${dayKey}`] = checkbox ? checkbox.checked : false;
            });
            
            // Verify at least one day is selected
            if (!Object.values(dayProperties).some(v => v === true)) {
                document.getElementById('daysError').classList.remove('hidden');
                return;
            }
            document.getElementById('daysError').classList.add('hidden');
            
            // Check category limit
            const categoryCount = habits.filter(h => h.category === selectedCategory && h.habit_id !== editingHabit?.habit_id).length;
            if (categoryCount >= 5) {
                document.getElementById('categoryLimitMsg').textContent = `You can track up to 5 ${selectedCategory} habits at a time.`;
                document.getElementById('categoryLimitMsg').classList.remove('hidden');
                return;
            }
            
            if (habits.length >= 999 && !editingHabit) {
                document.getElementById('categoryLimitMsg').textContent = 'Maximum limit of 999 habits reached.';
                document.getElementById('categoryLimitMsg').classList.remove('hidden');
                return;
            }
            
            saveBtn.disabled = true;
            saveBtn.textContent = 'Saving...';
            
            // Calculate next sort_order for this category
            const categoryHabits = getHabitsForCategory(selectedCategory);
            const nextSortOrder = categoryHabits.length;
            
            const habitData = {
                habit_id: editingHabit?.habit_id || `habit_${Date.now()}`,
                name,
                category: selectedCategory,
                date_created: editingHabit?.date_created || new Date().toISOString(),
                ...dayProperties,
                completions: editingHabit?.completions || '{}',
                current_streak: editingHabit?.current_streak || 0,
                longest_streak: editingHabit?.longest_streak || 0,
                sort_order: editingHabit?.sort_order ?? nextSortOrder
            };
            
            if (editingHabit) {
                const idx = habits.findIndex(h => h.habit_id === editingHabit.habit_id);
                if (idx !== -1) {
                    habits[idx] = habitData;
                }
            } else {
                habits.push(habitData);
            }
            
            saveHabits();
            saveBtn.disabled = false;
            saveBtn.textContent = editingHabit ? 'Save Changes' : 'Save Habit';
            closeModal();
            renderCalendar();
            renderHabits();
            updateProgress();
        }
        
        function openDeleteModal(habit) {
            deletingHabit = habit;
            deleteModal.classList.remove('hidden');
        }
        
        function closeDeleteModal() {
            deleteModal.classList.add('hidden');
            deletingHabit = null;
        }
        
        function handleConfirmDelete() {
            if (!deletingHabit) return;
            
            confirmDelete.disabled = true;
            confirmDelete.textContent = 'Deleting...';
            
            habits = habits.filter(h => h.habit_id !== deletingHabit.habit_id);
            saveHabits();
            
            confirmDelete.disabled = false;
            confirmDelete.textContent = 'Delete';
            closeDeleteModal();
            renderCalendar();
            renderHabits();
            updateProgress();
        }
        
        // Initialize app
        init();
