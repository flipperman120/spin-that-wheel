      <div class="grid grid-cols-3 gap-2">
       <button type="button" class="category-btn py-3 px-4 border-2 border-gray-200 font-medium transition-all" style="border-radius: 8px; font-family: Okomito; font-weight: 700; font-style: normal; font-size: 16px;" data-category="Morning" data-template-id="category-morning-btn">Morning</button> <button type="button" class="category-btn py-3 px-4 border-2 border-gray-200 font-medium transition-all" style="border-radius: 8px; font-family: Okomito; font-weight: 700; font-style: normal; font-size: 16px;" data-category="Noon" data-template-id="category-noon-btn">Noon</button> <button type="button" class="category-btn py-3 px-4 border-2 border-gray-200 font-medium transition-all" style="border-radius: 8px; font-family: Okomito; font-weight: 700; font-style: normal; font-size: 16px;" data-category="Evening" data-template-id="category-evening-btn">Evening</button>
