     </div>
     <div id="calendarGrid" class="grid grid-cols-7 gap-2"></div><button id="returnToday" class="btn-primary w-full mt-4 py-3 font-medium flex items-center justify-center gap-2"> <i data-lucide="calendar-check" class="w-5 h-5"></i> <span data-template-id="return-today-btn" style="color: rgb(255, 255, 255); font-family: Okomito; font-weight: 700; font-style: normal; font-size: 16px;">Return to today</span> </button> <button id="addHabitBtn" class="btn-primary w-full mt-4 py-3 font-medium flex items-center justify-center gap-2"> <i data-lucide="plus" class="w-5 h-5"></i> <span data-template-id="add-habit-btn" style="color: rgb(255, 255, 255); font-family: Okomito; font-weight: 700; font-style: normal; font-size: 16px;">Add habit</span> </button>
    </div><!-- Motivational Statement -->
    <p data-template-id="motivational-text" class="text-sm font-medium text-left mt-auto hidden md:block" style="color: rgb(255, 255, 255); margin-top: 20px; font-weight: 400; font-style: normal; font-size: 18px;">Every small step counts. 
Track your progress with confidence.</p>
   </aside><!-- Main Content -->
   <main class="main-content flex-1 flex flex-col">
    <div class="glass soft-gradient p-6" style="position: relative; overflow: hidden; border-radius: 10px; background: linear-gradient(rgb(191, 204, 252), rgb(250, 244, 248));" data-template-id="content-gradient"><!-- Selected Date Display -->
     <div class="flex items-center gap-3 mb-6 relative z-10">
      <div class="w-11 h-11 flex items-center justify-center rounded-full" style="background-color: #205182;">
       <i data-lucide="calendar" class="w-6 h-6 text-white"></i>
      </div>
