        function calculateStreakFromCompletions(completions, habitCreatedDate) {
            // Calculate current streak starting from today and going backwards
            let currentStreak = 0;
            const createdDate = new Date(habitCreatedDate);
            createdDate.setHours(0, 0, 0, 0);
            
            let checkDate = new Date(today);
            while (checkDate >= createdDate) {
                const dateStr = checkDate.toISOString().split('T')[0];
                if (completions[dateStr] === true) {
                    currentStreak++;
                    checkDate.setDate(checkDate.getDate() - 1);
                } else {
                    break;
                }
            }
            
            return currentStreak;
        }
        
        function calculateLongestStreak(completions, habitCreatedDate) {
            // Calculate longest streak by finding all consecutive completion sequences
            let longestStreak = 0;
            let currentStreak = 0;
            
            const createdDate = new Date(habitCreatedDate);
            createdDate.setHours(0, 0, 0, 0);
            
            let checkDate = new Date(createdDate);
            const endDate = new Date(today);
            endDate.setDate(endDate.getDate() + 1); // Include today
            
            while (checkDate <= endDate) {
                const dateStr = checkDate.toISOString().split('T')[0];
                if (completions[dateStr] === true) {
                    currentStreak++;
                    longestStreak = Math.max(longestStreak, currentStreak);
                } else {
                    currentStreak = 0;
                }
                checkDate.setDate(checkDate.getDate() + 1);
            }
            
            return longestStreak;
        }
        
        function handleToggleHabit(habit, completed) {
            if (isLoading) return;
            isLoading = true;
            
            // Validate that habit is scheduled for this day
            const dayKey = dayKeys[selectedDate.getDay()];
            const repeatKey = `repeatable_${dayKey}`;
            const isDaySelected = habit[repeatKey] === true;
            
            if (!isDaySelected) {
                // Habit not scheduled for this day - uncheck and abort
                const checkbox = document.querySelector(`#habit-${habit.habit_id}`);
                if (checkbox) checkbox.checked = false;
                isLoading = false;
                return;
            }
            
            const dateStr = selectedDate.toISOString().split('T')[0];
            let completions = {};
            try {
                completions = JSON.parse(habit.completions || '{}');
            } catch {}
            
            const wasCompleted = completions[dateStr] === true;
            completions[dateStr] = completed;
            
            // Recalculate streaks based on all completions
            const newStreak = calculateStreakFromCompletions(completions, habit.date_created);
            const longestStreak = calculateLongestStreak(completions, habit.date_created);
            
            // Pulse animation for streak
            if (completed && !wasCompleted) {
                const card = document.querySelector(`[data-habit-id="${habit.habit_id}"]`);
                if (card) {
                    const streakEl = card.querySelector('[data-lucide="flame"]');
                    if (streakEl) {
                        streakEl.parentElement.classList.add('streak-pulse');
                        setTimeout(() => streakEl.parentElement.classList.remove('streak-pulse'), 300);
                    }
                }
            }
            
            habit.completions = JSON.stringify(completions);
            habit.current_streak = newStreak;
            habit.longest_streak = longestStreak;
            
            saveHabits();
            renderHabits();
            updateProgress();
            
            isLoading = false;
        }
        
        function updateProgress() {
            const dayHabits = getHabitsForDate(selectedDate);
            const completed = dayHabits.filter(h => isHabitCompletedOnDate(h, selectedDate)).length;
            const total = dayHabits.length;
            
            const percent = total > 0 ? (completed / total) * 100 : 0;
            progressBar.style.width = `${percent}%`;
            progressText.textContent = `${completed} of ${total} completed`;
            
            // Celebration when all complete
            if (total > 0 && completed === total) {
                const progressSection = document.getElementById('progressSection');
                progressSection.classList.add('celebrate');
                createConfetti();
                setTimeout(() => progressSection.classList.remove('celebrate'), 500);
            }
        }
        
        function createConfetti() {
            const colors = ['#6BA3D6', '#A8C8E8', '#D4E5F7', '#E8D5E8'];
            
            // Determine piece count based on motion preferences
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            const pieceCount = prefersReducedMotion ? 20 : 120;
            const duration = prefersReducedMotion ? 700 : 3500;
            
            // Create overlay container for all confetti (fixed 100vw x 100vh)
            const overlay = document.createElement('div');
            overlay.className = 'confetti-overlay';
            overlay.style.width = '100vw';
            overlay.style.height = '100vh';
            document.body.appendChild(overlay);
            
            for (let i = 0; i < pieceCount; i++) {
                const piece = document.createElement('div');
                piece.className = 'confetti-piece';
                piece.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                piece.style.left = `${Math.random() * 100}%`;
                piece.style.top = '-12px';
                
                // Random animation delay between 0-0.5s for staggered effect
                const delay = Math.random() * 0.5;
                piece.style.animationDelay = `${delay}s`;
                
                // Random horizontal drift between -300px and 300px
                const drift = (Math.random() - 0.5) * 600;
                piece.style.setProperty('--drift', `${drift}px`);
                
                overlay.appendChild(piece);
            }
            
            // Remove overlay after animation completes
            setTimeout(() => {
                overlay.remove();
            }, duration + 500);
        }
        
        function openModal(habit = null) {
            editingHabit = habit;
            modalTitle.textContent = habit ? 'Edit Habit' : 'Add New Habit';
            saveBtn.textContent = habit ? 'Save Changes' : 'Save Habit';
            
            // Always initialize all day checkboxes to unchecked first
            dayBtns.forEach(btn => {
