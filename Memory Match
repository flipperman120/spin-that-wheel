  <script>
        // Update top bar background color from config when it loads
        const topBarBgEl = document.querySelector('[data-template-id="top-bar-background"]');
        const topBar = document.querySelector('.top-bar');
        
        function updateTopBarBackground() {
            if (topBarBgEl && topBarBgEl.style.background) {
                topBar.style.background = topBarBgEl.style.background;
            }
        }

        // Update on initial load
        updateTopBarBackground();

        // Also watch for attribute changes
        const observer = new MutationObserver(updateTopBarBackground);
        if (topBarBgEl) {
            observer.observe(topBarBgEl, { attributes: true, attributeFilter: ['style'] });
        }

        // Sync Home button outline color with config background property
        const gameHomBtn = document.querySelector('[data-template-id="game-home-btn"]');
        
        function syncHomeButtonOutlineColor() {
            if (gameHomBtn) {
                const bgValue = gameHomBtn.style.background;
                if (bgValue && bgValue !== 'transparent') {
                    gameHomBtn.style.borderColor = bgValue;
                    gameHomBtn.style.background = 'transparent';
                }
            }
        }

        // Initial sync
        syncHomeButtonOutlineColor();

        // Watch for changes from the SDK
        const homeButtonObserver = new MutationObserver(syncHomeButtonOutlineColor);
        if (gameHomBtn) {
            homeButtonObserver.observe(gameHomBtn, { attributes: true, attributeFilter: ['style'] });
        }

        // Game state
        let selectedTime = 60;
        let timeRemaining = 60;
        let timerInterval = null;
        let revealedCards = [];
        let matchedPairs = [];
        let cards = [];
        let isProcessing = false;
        const totalPairs = 8;

        // Image sources pulled from SDK-populated hidden elements
        function getCardImages() {
            const images = [];
            for (let i = 1; i <= 8; i++) {
                const el = document.querySelector(`[data-template-id="card-image-${i}"]`);
                images.push({
                    id: i,
                    src: el ? el.src : '',
                    alt: el ? el.alt : `Card ${i}`
                });
            }
            return images;
        }

        function selectTime(time, btn) {
            selectedTime = time;
            document.querySelectorAll('.time-option').forEach(b => {
                b.classList.remove('selected');
                b.setAttribute('aria-checked', 'false');
                b.style.background = '';
                b.style.color = '';
                b.style.borderColor = '';
            });
            btn.classList.add('selected');
            btn.setAttribute('aria-checked', 'true');
            btn.style.background = '#fb64d0';
            btn.style.color = '#FFFFFF';
            btn.style.borderColor = '#fb64d0';
        }

        function shuffle(arr) {
            const a = [...arr];
            for (let i = a.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [a[i], a[j]] = [a[j], a[i]];
            }
            return a;
        }

        function showScreen(id) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }

        function startGame() {
            timeRemaining = selectedTime;
            matchedPairs = [];
            revealedCards = [];
            isProcessing = false;
            buildGrid();
            showScreen('game-screen');
            updateTimerDisplay();
            startTimer();
        }

        function buildGrid() {
            const grid = document.getElementById('card-grid');
            grid.innerHTML = '';
            // Create pairs: two of each image (card-image-1 through card-image-8)
            const pairs = [];
            for (let i = 1; i <= totalPairs; i++) {
                pairs.push({ pairId: i, cardId: i, uniqueId: i + '-a' });
                pairs.push({ pairId: i, cardId: i, uniqueId: i + '-b' });
            }
            cards = shuffle(pairs);

            const template = document.getElementById('card-template');
            cards.forEach((card, index) => {
                const el = template.content.cloneNode(true);
                const cardEl = el.querySelector('.memory-card');
                cardEl.dataset.pairId = card.pairId;
                cardEl.dataset.uid = card.uniqueId;
                cardEl.dataset.index = index;

                // Set card number on back face
                const cardNumber = cardEl.querySelector('.card-number');
                cardNumber.textContent = String(index + 1);

                // Set card image with data-template-id for direct editing
                const cardImg = cardEl.querySelector('.card-image');
                cardImg.setAttribute('data-template-id', `card-image-${card.cardId}`);
                
                // Load image from SDK config if available
                const imgEl = document.querySelector(`[data-template-id="card-image-${card.cardId}"]`);
                if (imgEl && imgEl.src) {
                    cardImg.src = imgEl.src;
                    cardImg.alt = imgEl.alt || `Card ${card.cardId}`;
                }

                cardEl.addEventListener('click', () => flipCard(cardEl));
                cardEl.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        flipCard(cardEl);
                    }
                });

                grid.appendChild(el);
            });
        }

        function flipCard(cardEl) {
            // Prevent interaction with matched cards
            if (cardEl.classList.contains('matched')) return;
            if (isProcessing) return;
            if (cardEl.classList.contains('flipped')) return;
            if (revealedCards.length >= 2) return;

            cardEl.classList.add('flipped');
            cardEl.setAttribute('aria-label', `Card revealed`);
            revealedCards.push(cardEl);

            if (revealedCards.length === 2) {
                isProcessing = true;
                const [first, second] = revealedCards;

                if (first.dataset.pairId === second.dataset.pairId) {
                    // Match found
                    setTimeout(() => {
                        first.classList.add('matched');
                        second.classList.add('matched');
                        first.setAttribute('aria-label', `Matched`);
                        second.setAttribute('aria-label', `Matched`);
                        matchedPairs.push(first.dataset.pairId);
                        revealedCards = [];
                        isProcessing = false;

                        if (matchedPairs.length === totalPairs) {
                            endGame(true);
                        }
                    }, 400);
                } else {
                    // No match — flip back
                    setTimeout(() => {
                        first.classList.remove('flipped');
                        second.classList.remove('flipped');
                        first.setAttribute('aria-label', 'Memory card, face down');
                        second.setAttribute('aria-label', 'Memory card, face down');
                        revealedCards = [];
                        isProcessing = false;
                    }, 800);
                }
            }
        }

        function startTimer() {
            clearInterval(timerInterval);
            timerInterval = setInterval(() => {
                timeRemaining--;
                updateTimerDisplay();
                if (timeRemaining <= 0) {
                    clearInterval(timerInterval);
                    endGame(false);
                }
            }, 1000);
        }

        function updateTimerDisplay() {
            const el = document.querySelector('[data-template-id="timer-display"]');
            const mins = Math.floor(timeRemaining / 60);
            const secs = timeRemaining % 60;
            el.textContent = `${mins}:${secs.toString().padStart(2, '0')}`;

            if (timeRemaining <= 10 && timeRemaining > 0) {
                el.classList.add('timer-warning', 'timer-pulse');
            } else {
                el.classList.remove('timer-warning', 'timer-pulse');
            }
        }

        function endGame(won) {
            clearInterval(timerInterval);
            isProcessing = true;

            if (won) {
                const mins = Math.floor(timeRemaining / 60);
                const secs = timeRemaining % 60;
                const timeStr = mins > 0 ? `${mins}m ${secs}s` : `${secs}s`;
                document.getElementById('win-detail').textContent = `Time remaining: ${timeStr}`;
                document.getElementById('win-modal').classList.add('active');
            } else {
                document.getElementById('lose-detail').textContent = `You matched ${matchedPairs.length} of ${totalPairs} pairs.`;
                document.getElementById('lose-modal').classList.add('active');
            }
        }

        function closeModals() {
            document.getElementById('win-modal').classList.remove('active');
            document.getElementById('lose-modal').classList.remove('active');
        }

        function restartGame() {
            closeModals();
            startGame();
        }

        function goHome() {
            closeModals();
            clearInterval(timerInterval);
            showScreen('home-screen');
        }

        // Sync modal Home buttons outline color with config background property
        function setupModalHomeButtonObserver(btnId) {
            const btn = document.querySelector(`[data-template-id="${btnId}"]`);
            if (!btn) return;

            function syncOutlineColor() {
                const bgValue = btn.style.background;
                if (bgValue && bgValue !== 'transparent') {
                    btn.style.borderColor = bgValue;
                    btn.style.background = 'transparent';
                }
            }

            // Initial sync
            syncOutlineColor();

            // Watch for changes from the SDK
            const observer = new MutationObserver(syncOutlineColor);
            observer.observe(btn, { attributes: true, attributeFilter: ['style'] });
        }

        // Setup observers for both modal home buttons
        setupModalHomeButtonObserver('win-home-btn');
        setupModalHomeButtonObserver('lose-home-btn');

        // Setup MutationObserver for time selector buttons to maintain selected state
        document.querySelectorAll('.time-option').forEach(btn => {
            const observer = new MutationObserver(() => {
                if (btn.classList.contains('selected')) {
                    btn.style.background = '#fb64d0';
                    btn.style.color = '#FFFFFF';
                    btn.style.borderColor = '#fb64d0';
                } else {
                    btn.style.background = '#FFFFFF';
                    btn.style.color = 'rgb(131, 12, 14)';
                    btn.style.borderColor = '';
                }
            });
            observer.observe(btn, { attributes: true, attributeFilter: ['style', 'class'] });
        });
