<!doctype html>
<html lang="en"><head><script src="/_sdk/telemetry_sdk.js"></script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Countdown Clock</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Space+Mono:wght@400;700&amp;display=swap" rel="stylesheet">
  <style>
        body { font-family: 'Inter', sans-serif; }
        .mono { font-family: 'Space Mono', monospace; }
    </style>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js" type="text/javascript"></script>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
  <script src="/_sdk/resizing_sdk.js" type="text/javascript"></script>
 </head>
 <body data-template-id="__page-root" class="w-full min-h-screen flex items-center justify-center p-4" style="background: linear-gradient(rgb(0, 0, 0), rgb(192, 131, 252), rgb(202, 217, 249));">
  <main class="w-full max-w-2xl mx-auto text-center space-y-8">
   <header>
    <h1 data-template-id="countdown-title" class="canva-text mono" style="color: rgb(255, 255, 255); font-weight: 400; font-style: normal; font-size: 89px; letter-spacing: -0.2rem;">Countdown Clock</h1>
    <p data-template-id="countdown-subtitle" class="canva-text mt-2" style="color: rgb(255, 255, 255); font-weight: 400; font-style: normal; font-size: 16px;">Set your target date and time</p>
   </header>
   <div id="input-row" class="flex flex-wrap items-end justify-center gap-4 mt-12">
    <div>
     <label data-template-id="date-label" for="date-input" class="canva-text block mb-1 text-left" style="color: rgb(255, 255, 255); font-weight: 500; font-style: normal; font-size: 14px;">Date</label> <input type="date" id="date-input" class="px-3 py-2 bg-white/10 border border-white/20 text-white focus:outline-none focus:ring-2 focus:ring-amber-400">
    </div>
    <div>
     <label data-template-id="time-label" for="time-input" class="canva-text block mb-1 text-left" style="color: rgb(255, 255, 255); font-weight: 500; font-style: normal; font-size: 14px;">Time</label> <input type="time" id="time-input" class="px-3 py-2 bg-white/10 border border-white/20 text-white focus:outline-none focus:ring-2 focus:ring-amber-400">
    </div>
    <div class="flex gap-2">
     <button data-template-id="start-btn" class="canva-button px-5 py-2 font-medium transition transform hover:scale-105 hover:shadow-lg" onclick="startCountdown()" style="background: rgb(255, 255, 255); color: rgb(0, 0, 0); font-weight: 700; font-style: normal; font-size: 16px;">Start</button> <button data-template-id="reset-btn" class="canva-button px-5 py-2 font-medium transition transform hover:scale-105 hover:shadow-lg" onclick="resetCountdown()" style="background: rgb(0, 0, 0); color: rgb(255, 255, 255); font-weight: 600; font-style: normal; font-size: 16px;">Reset</button>
    </div>
   </div>
   <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
    <div data-template-id="card-days" class="canva-card p-6" style="background: rgb(255, 255, 255);">
     <div id="num-days" class="text-5xl font-bold" style="color: #000000; font-family: 'Inter', sans-serif;">
      00
     </div>
     <div data-template-id="days-label" class="canva-text mt-2" style="color: rgb(0, 0, 0); font-weight: 500; font-style: normal; font-size: 13px;">Days</div>
    </div>
    <div data-template-id="card-hours" class="canva-card p-6" style="background: rgb(255, 255, 255);">
     <div id="num-hours" class="text-5xl font-bold" style="color: #000000; font-family: 'Inter', sans-serif;">
      00
     </div>
     <div data-template-id="hours-label" class="canva-text mt-2" style="color: rgb(0, 0, 0); font-weight: 500; font-style: normal; font-size: 13px;">Hours</div>
    </div>
    <div data-template-id="card-minutes" class="canva-card p-6" style="background: rgb(255, 255, 255);">
     <div id="num-minutes" class="text-5xl font-bold" style="color: #000000; font-family: 'Inter', sans-serif;">
      00
     </div>
     <div data-template-id="minutes-label" class="canva-text mt-2" style="color: rgb(0, 0, 0); font-weight: 500; font-style: normal; font-size: 13px;">Minutes</div>
    </div>
    <div data-template-id="card-seconds" class="canva-card p-6" style="background: rgb(255, 255, 255);">
     <div id="num-seconds" class="text-5xl font-bold" style="color: #000000; font-family: 'Inter', sans-serif;">
      00
     </div>
     <div data-template-id="seconds-label" class="canva-text mt-2" style="color: rgb(0, 0, 0); font-weight: 500; font-style: normal; font-size: 13px;">Seconds</div>
    </div>
   </div>
   <p data-template-id="finished-msg" class="canva-text mono hidden" style="color: rgb(245, 158, 11); font-weight: 700; font-style: normal; font-size: 32px;">🎉 Time's Up!</p>
  </main>
  <script src="/_sdk/editing_sdk.js"></script>
  <script>
        let interval = null;

        function startCountdown() {
            const d = document.getElementById('date-input').value;
            const t = document.getElementById('time-input').value || '00:00';
            if (!d) return;
            clearInterval(interval);
            const target = new Date(`${d}T${t}`).getTime();
            document.querySelector('[data-template-id="finished-msg"]').classList.add('hidden');
            tick(target);
            interval = setInterval(() => tick(target), 1000);
        }

        function tick(target) {
            const diff = Math.max(0, target - Date.now());
            const s = Math.floor(diff / 1000);
            document.getElementById('num-days').textContent = String(Math.floor(s / 86400)).padStart(2, '0');
            document.getElementById('num-hours').textContent = String(Math.floor((s % 86400) / 3600)).padStart(2, '0');
            document.getElementById('num-minutes').textContent = String(Math.floor((s % 3600) / 60)).padStart(2, '0');
            document.getElementById('num-seconds').textContent = String(s % 60).padStart(2, '0');
            if (diff <= 0) {
                clearInterval(interval);
                interval = null;
                document.querySelector('[data-template-id="finished-msg"]').classList.remove('hidden');
            }
        }

        function resetCountdown() {
            clearInterval(interval);
            interval = null;
            ['num-days','num-hours','num-minutes','num-seconds'].forEach(id => document.getElementById(id).textContent = '00');
            document.querySelector('[data-template-id="finished-msg"]').classList.add('hidden');
        }
    </script>
