     <h2 data-template-id="incorrect-heading" class="canva-text font-inclusive text-7xl font-bold mb-8" style="color: #fffdf1;"></h2>
     <p data-template-id="incorrect-caption" class="canva-text font-nunito text-xl mb-4" style="color: #fffdf1;"></p>
     <div data-template-id="incorrect-answer-display" class="canva-text font-nunito font-semibold mb-12" style="background: var(--lime); padding: 16px 32px; border-radius: 0; text-align: center; font-size: 24px; color: #000000;"></div><button data-template-id="incorrect-continue-button" class="canva-button btn-primary" onclick="nextQuestion()" style="padding: 25.2px 107.52px; background: var(--lime); color: #000000; border: 3px solid #000000;"></button>
    </div>
   </div>
  </template><!-- Turn Complete -->
  <template id="turn-complete-template">
   <div data-template-id="turn-complete-bg" class="canva-section w-full flex scale-in" style="height: calc(100 * min(var(--vh, 1vh), 1vh)); background: var(--sky); display: grid; grid-template-columns: minmax(38%, 400px) 1fr; gap: 0;">
    <div class="flex items-center justify-center" style="padding: 40px; background: var(--sky);"><img data-template-id="turn-complete-photo" class="canva-image w-full object-cover rounded-[40px] border-4 border-black" loading="lazy" alt="Turn complete photo" style="aspect-ratio: 3 / 4.5; max-width: 100%; max-height: 100%;">
    </div>
    <div class="flex flex-col items-center justify-center" style="padding: 60px 40px; background: var(--sky); display: flex; flex-direction: column; justify-content: center; align-items: center;">
     <h2 data-template-id="turn-complete-heading" class="canva-text font-inclusive text-7xl font-bold mb-6" style="color: #fffdf1;"></h2>
     <p data-template-id="turn-complete-pass-text" class="canva-text font-nunito text-2xl mb-8" style="color: #fffdf1;"></p>
     <p id="turn-next-player-name" class="font-nunito font-bold text-3xl mb-12" style="color: #fffdf1;"></p>
     <div id="score-pill" class="flex items-center gap-4" style="background: #fffdf1; border: 4px solid #000000; border-radius: 50px; padding: 12px 24px; margin-bottom: 32px; max-width: 520px; min-height: 80px; justify-content: center;">
      <div id="turn-player-avatar" class="avatar" style="width: 56px; height: 56px; flex-shrink: 0; border-radius: 50%; font-size: 1.5rem;"></div><span id="turn-player-name-pill" class="font-nunito font-semibold text-xl" style="color: var(--dark); flex: 1;"></span> <span id="turn-player-round-score" class="font-nunito font-bold text-4xl" style="color: var(--pink);"></span>
     </div><button data-template-id="turn-complete-ready-button" class="canva-button btn-secondary" onclick="continueAfterTurn()" style="padding: 18px 56px; background: var(--lime); color: #000000; border: 3px solid #000000;"></button>
    </div>
   </div>
  </template><!-- Round Complete -->
  <template id="round-complete-template">
   <div data-template-id="scoreboard-screen-bg" class="canva-section w-full" style="display: grid; grid-template-columns: minmax(38%, 400px) 1fr; min-height: calc(100 * min(var(--vh, 1vh), 1vh)); background: var(--sky); gap: 0;">
    <div class="flex items-center justify-center" style="padding: 40px; background: var(--sky);"><img data-template-id="scoreboard-portrait-photo" class="canva-image w-full object-cover rounded-[40px] border-4 border-black" loading="lazy" alt="Scoreboard portrait" style="aspect-ratio: 3 / 4.5; max-width: 100%; max-height: 100%;">
    </div>
    <div class="flex flex-col items-center justify-center" style="padding: 60px 40px; background: var(--sky); display: flex; flex-direction: column; justify-content: center; align-items: center;">
     <h2 data-template-id="scoreboard-heading" class="canva-text font-inclusive text-7xl font-bold mb-12" style="color: #fffdf1;"></h2>
     <div id="round-scores-container" class="w-full" style="display: flex; flex-direction: column; gap: 20px; margin-bottom: 40px; max-width: 530px;"></div><button id="next-round-btn" data-template-id="scoreboard-continue-button" class="canva-button btn-secondary" style="padding: 18px 56px; background: var(--lime); color: #000000; border: 3px solid #000000;" onclick="nextRound()"></button>
    </div><!-- Hidden reference elements for scoreboard row styling -->
    <div data-template-id="scoreboard-row-style" style="display: none; background: #fffdf1; border-color: var(--pink); color: var(--dark);"></div><span data-template-id="scoreboard-score-style" style="display: none; color: var(--pink);"></span>
   </div>
  </template><!-- Game Over -->
  <template id="game-over-template">
   <div data-template-id="game-over-screen-bg" class="canva-section w-full" style="display: grid; grid-template-columns: minmax(38%, 400px) 1fr; min-height: calc(100 * min(var(--vh, 1vh), 1vh)); background: #59b0f7; gap: 0;">
    <div class="flex items-center justify-center" style="padding: 40px; background: #59b0f7;"><img data-template-id="game-over-portrait-photo" class="canva-image w-full object-cover rounded-[40px] border-4 border-black" loading="lazy" alt="Game over portrait" style="aspect-ratio: 3 / 4.5; max-width: 100%; max-height: 100%;">
    </div>
    <div class="flex flex-col items-center justify-center" style="padding: 60px 40px; background: #59b0f7; display: flex; flex-direction: column; justify-content: center; align-items: center;">
     <h2 data-template-id="game-over-title" class="canva-text font-inclusive text-6xl font-bold mb-4" style="color: var(--dark);"></h2>
     <p id="winner-text" data-template-id="winner-text" class="canva-text text-xl font-semibold mb-12 text-center font-nunito" style="color: var(--dark);"></p>
     <div id="final-scores-container" class="w-full" style="display: flex; flex-direction: column; gap: 20px; margin-bottom: 40px; max-width: 530px;"></div>
     <div class="flex flex-col sm:flex-row gap-4">
      <button data-template-id="play-again-button" class="canva-button btn-primary" style="padding: 18px 56px; background: var(--pink); color: #000000; border: 3px solid #000000;" onclick="playAgain()"></button> <button data-template-id="new-game-button" class="canva-button btn-secondary" style="padding: 18px 56px; background: var(--lime); color: #000000; border: 3px solid #000000;" onclick="newGame()"></button>
     </div>
    </div>
   </div>
  </template>
  <script src="/_sdk/editing_sdk.js"></script>
  <script>

    // ---- QUIZ DATA ----
    const AVATAR_COLORS = ['#FF4FCB','#A7C7FF','#D7FF3F','#FFA94D','#A78BFA','#34D399'];

    const ROUNDS = [
        {
            type: 'multiple-choice',
            title: 'Multiple Choice',
            description: 'Pick the correct answer from four options.',
            questions: [
                { question: 'What is the largest planet in our solar system?', category: 'Science', options: ['Mars','Jupiter','Saturn','Neptune'], answer: 'Jupiter' },
                { question: 'Which country is home to the kangaroo?', category: 'Geography', options: ['New Zealand','South Africa','Australia','Brazil'], answer: 'Australia' },
                { question: 'Who painted the Mona Lisa?', category: 'Art', options: ['Van Gogh','Da Vinci','Picasso','Monet'], answer: 'Da Vinci' },
                { question: 'What is the chemical symbol for gold?', category: 'Science', options: ['Go','Gd','Au','Ag'], answer: 'Au' },
                { question: 'In which year did the Titanic sink?', category: 'History', options: ['1905','1912','1920','1898'], answer: '1912' }
            ]
        },
        {
            type: 'fill-in-the-blank',
            title: 'Fill in the Blank',
            description: 'Type the correct answer to complete the statement.',
            questions: [
                { question: 'The capital of France is _____.', category: 'Geography', answer: 'paris' },
                { question: 'Water freezes at _____ degrees Celsius.', category: 'Science', answer: '0' },
                { question: 'The Great Wall is located in _____.', category: 'Geography', answer: 'china' },
                { question: 'A group of lions is called a _____.', category: 'Nature', answer: 'pride' },
                { question: 'The currency of Japan is the _____.', category: 'Culture', answer: 'yen' }
            ]
        },
        {
            type: 'enumeration',
            title: 'Enumeration',
            description: 'List all the correct items to score points.',
            questions: [
                { question: 'Name 3 primary colors.', category: 'Art', answers: ['red','blue','yellow'], count: 3 },
                { question: 'Name 3 states of matter.', category: 'Science', answers: ['solid','liquid','gas'], count: 3 },
                { question: 'Name 4 cardinal directions.', category: 'Geography', answers: ['north','south','east','west'], count: 4 },
                { question: 'Name 3 planets closest to the Sun.', category: 'Science', answers: ['mercury','venus','earth'], count: 3 }
            ]
        },
        {
            type: 'image-identification',
            title: 'Image Identification',
            description: 'Identify what you see in the image.',
            questions: [
                { question: 'Which part of a cat is also called vibrissae?', category: 'Animals', options: ['Tail','Whiskers','Ears','Claws'], answer: 'Whiskers' },
                { question: 'What is this pastry called?', category: 'Food', options: ['Brioche','Baguette','Croissant','Éclair'], answer: 'Croissant' },
                { question: 'What determines the feel of each keypress on a keyboard?', category: 'Tech', options: ['Switch','Cable','Port','Keys'], answer: 'Switch' },
                { question: 'Gua Sha is a traditional healing technique that originated in which country?', category: 'Medicine', options: ['Japan','China','Korea','Thailand'], answer: 'China' }
            ]
        }
    ];

    // ---- GAME STATE ----
    let gameState = {
        mode: 'solo',
        players: [],
        currentRound: 0,
        currentQuestion: 0,
        currentPlayerIndex: 0,
        scores: {},
        roundScores: {},
        selectedAnswer: null
    };

    const container = document.getElementById('game-container');

    // ---- SCREEN RENDERING ----
    function showStartScreen() {
        const tpl = document.getElementById('start-screen-template');
        container.innerHTML = '';
        container.appendChild(tpl.content.cloneNode(true));
        lucide.createIcons();
    }

    function startSolo() {
        gameState = { mode: 'solo', players: [{ name: 'You', color: AVATAR_COLORS[0] }], currentRound: 0, currentQuestion: 0, currentPlayerIndex: 0, scores: { 'You': 0 }, roundScores: {}, selectedAnswer: null };
        showRoundIntro();
    }

    function startMultiplayer() {
        const tpl = document.getElementById('player-setup-template');
        container.innerHTML = '';
        container.appendChild(tpl.content.cloneNode(true));
        const countGroup = document.getElementById('player-count-group');
        for (let i = 2; i <= 4; i++) {
            const btn = document.createElement('button');
            btn.setAttribute('data-template-id', `setup-player-count-${i}`);
            btn.className = 'canva-button player-count-circle';
            btn.textContent = i;
            btn.setAttribute('role', 'radio');
            btn.setAttribute('aria-checked', 'false');
            btn.setAttribute('aria-label', i + ' players');
            btn.onclick = () => selectPlayerCount(i);
            countGroup.appendChild(btn);
        }
        // Default to 2 players on load
        selectPlayerCount(2);
    }

    function selectPlayerCount(count) {
        const btns = document.querySelectorAll('#player-count-group button');
        btns.forEach((b, idx) => {
            const isSelected = (idx + 2) === count;
            b.classList.toggle('selected', isSelected);
            b.setAttribute('aria-checked', isSelected ? 'true' : 'false');
        });
        const namesContainer = document.getElementById('player-names-container');
        namesContainer.innerHTML = '';
        for (let i = 0; i < count; i++) {
            const wrapper = document.createElement('div');
            wrapper.style.cssText = 'display: flex; flex-direction: column; gap: 4px;';
            const label = document.createElement('label');
            label.setAttribute('data-template-id', `setup-player-label-${i + 1}`);
            label.className = 'canva-text block font-semibold text-xs';
            label.style.color = '#1a1a2e';
            label.style.textAlign = 'center';
            label.textContent = `PLAYER ${i + 1}`;
            label.setAttribute('for', `player-name-${i}`);
            const input = document.createElement('input');
            input.type = 'text';
            input.id = `player-name-${i}`;
            input.setAttribute('data-template-id', `setup-player-input-${i + 1}`);
            input.className = 'player-input-field';
            input.placeholder = `Enter name...`;
            input.maxLength = 20;
            input.oninput = validatePlayerNames;
            wrapper.appendChild(label);
            wrapper.appendChild(input);
            namesContainer.appendChild(wrapper);
        }
        validatePlayerNames();
    }

    function validatePlayerNames() {
        const inputs = document.querySelectorAll('#player-names-container input');
        const allFilled = inputs.length > 0 && [...inputs].every(i => i.value.trim().length > 0);
        document.getElementById('start-game-btn').disabled = !allFilled;
    }

    function startGame() {
        const inputs = document.querySelectorAll('#player-names-container input');
        const players = [...inputs].map((inp, idx) => ({ name: inp.value.trim(), color: AVATAR_COLORS[idx % AVATAR_COLORS.length] }));
        const scores = {};
        players.forEach(p => scores[p.name] = 0);
        gameState = { mode: 'multiplayer', players, currentRound: 0, currentQuestion: 0, currentPlayerIndex: 0, scores, roundScores: {}, selectedAnswer: null };
        showRoundIntro();
    }

    function showRoundIntro() {
        const round = ROUNDS[gameState.currentRound];
        gameState.currentQuestion = 0;
        gameState.currentPlayerIndex = 0;
        gameState.roundScores = {};
        gameState.players.forEach(p => gameState.roundScores[p.name] = 0);

        const templateId = `round-${gameState.currentRound + 1}-template`;
        const tpl = document.getElementById(templateId);
        container.innerHTML = '';
        container.appendChild(tpl.content.cloneNode(true));

        // Hide nav controls
        document.getElementById('nav-controls').classList.add('hidden');

        const playerIndicator = document.querySelector('[data-template-id*="player-indicator"]');
        const playerInfo = document.getElementById('current-player-info');
        if (gameState.mode === 'multiplayer') {
            const cp = gameState.players[gameState.currentPlayerIndex];
            playerInfo.textContent = `${cp.name}'s turn first!`;
            if (playerIndicator) playerIndicator.style.display = 'flex';
        } else {
            playerInfo.textContent = '';
            if (playerIndicator) playerIndicator.style.display = 'none';
        }
    }

    function startRound() {
        showQuestion();
    }

    function showQuestion() {
        const round = ROUNDS[gameState.currentRound];
        const qIdx = gameState.currentQuestion;
        if (qIdx >= round.questions.length) {
            showRoundComplete();
            return;
        }
        const q = round.questions[qIdx];
        gameState.selectedAnswer = null;

        const tpl = document.getElementById('question-screen-template');
        container.innerHTML = '';
        container.appendChild(tpl.content.cloneNode(true));

        // Add special class for Round 1 questions 1-5 styling (pill-shaped buttons)
        if (gameState.currentRound === 0 && qIdx <= 4) {
            const answerArea = document.getElementById('answer-area');
            answerArea.classList.add(`round-1-q${qIdx + 1}`);
        }

        // Add special class for Round 4 questions 1-4 styling (pill-shaped buttons)
        if (gameState.currentRound === 3 && qIdx <= 3) {
            const answerArea = document.getElementById('answer-area');
            answerArea.classList.add(`round-4-q${qIdx + 1}`);
        }

        // Show nav controls
        updateNavControls();

        // Progress
        const total = round.questions.length;
        document.getElementById('question-progress-text').textContent = `Question ${qIdx + 1} of ${total}`;
        const cp = gameState.players[gameState.currentPlayerIndex];
        document.getElementById('question-score-text').textContent = `Score: ${gameState.scores[cp.name]}`;
        document.getElementById('question-progress-bar').style.width = `${((qIdx) / total) * 100}%`;
        setTimeout(() => {
            const bar = document.getElementById('question-progress-bar');
            if (bar) bar.style.width = `${((qIdx + 1) / total) * 100}%`;
        }, 100);

        // Category & question - set data-template-id for editability
        const categoryBadgeEl = document.getElementById('question-category-badge');
        const questionTextEl = document.getElementById('question-text');
        
        // Set unique template ID for this question
        const roundNum = gameState.currentRound + 1;
        const qNum = gameState.currentQuestion + 1;
        const questionTemplateId = `round-${roundNum}-q${qNum}-question`;
        const categoryTemplateId = `round-${roundNum}-q${qNum}-category`;
        
        questionTextEl.setAttribute('data-template-id', questionTemplateId);
        categoryBadgeEl.setAttribute('data-template-id', categoryTemplateId);
        
        // Only populate from question data if element is completely empty
        // This preserves user-edited text from config.json via the SDK
        if (!questionTextEl.textContent || questionTextEl.textContent.trim() === '') {
            questionTextEl.textContent = q.question || '';
        }
        
        if (!categoryBadgeEl.textContent || categoryBadgeEl.textContent.trim() === '') {
            categoryBadgeEl.textContent = q.category || '';
        }

        // Image - only show for Round 4 (uses data-template-id photo)
        const isRound4 = gameState.currentRound === 3;
        const imageContainer = document.getElementById('question-image-container');
        
        if (isRound4) {
            imageContainer.classList.remove('hidden');
            // Hide all photo frames first
            document.getElementById('photo-frame-q1').style.display = 'none';
            document.getElementById('photo-frame-q2').style.display = 'none';
            document.getElementById('photo-frame-q3').style.display = 'none';
            document.getElementById('photo-frame-q4').style.display = 'none';
            // Show the appropriate frame for this question
            const frameId = `photo-frame-q${gameState.currentQuestion + 1}`;
            const frame = document.getElementById(frameId);
            if (frame) frame.style.display = 'block';
        } else if (q.imageUrl) {
            imageContainer.classList.remove('hidden');
            // This shouldn't happen for current questions but kept for safety
        } else {
            imageContainer.classList.add('hidden');
        }

        // Answer area
        const answerArea = document.getElementById('answer-area');
        const submitBtn = document.getElementById('submit-answer-btn');

        // Hide submit button by default (only show for Round 2 and Round 3)
        submitBtn.classList.add('hidden');

        // Check if Round 1 - use static template buttons with unique templates per question
        if (gameState.currentRound === 0 && (round.type === 'multiple-choice' || round.type === 'image-identification')) {
            const templateId = `round-1-q${gameState.currentQuestion + 1}-answers-template`;
            const staticTpl = document.getElementById(templateId);
            if (staticTpl) {
                const fragment = staticTpl.content.cloneNode(true);
                const buttons = fragment.querySelectorAll('[data-template-id]');
                buttons.forEach((btn, idx) => {
                    // Only set text from data if button is empty (user hasn't customized via config)
                    if (!btn.textContent || btn.textContent.trim() === '') {
                        btn.textContent = q.options[idx];
                    }
                    btn.onclick = () => selectMCOption(btn, btn.textContent);
                });
                answerArea.appendChild(fragment);
            } else {
                // Fallback if template not found
                q.options.forEach(opt => {
                    const btn = document.createElement('button');
                    btn.className = 'option-btn';
                    btn.textContent = opt;
                    btn.onclick = () => selectMCOption(btn, opt);
                    answerArea.appendChild(btn);
                });
            }
        } else if (gameState.currentRound === 3 && round.type === 'image-identification') {
            // Round 4 - use static template buttons with unique templates per question
            const templateId = `round-4-q${gameState.currentQuestion + 1}-answers-template`;
            const staticTpl = document.getElementById(templateId);
            if (staticTpl) {
                const fragment = staticTpl.content.cloneNode(true);
                const buttons = fragment.querySelectorAll('[data-template-id]');
                buttons.forEach((btn, idx) => {
                    // Only set text from data if button is empty (user hasn't customized via config)
                    if (!btn.textContent || btn.textContent.trim() === '') {
                        btn.textContent = q.options[idx];
                    }
                    btn.onclick = () => selectMCOption(btn, btn.textContent);
                });
                answerArea.appendChild(fragment);
            } else {
                // Fallback if template not found
                q.options.forEach(opt => {
                    const btn = document.createElement('button');
                    btn.className = 'option-btn';
                    btn.textContent = opt;
                    btn.onclick = () => selectMCOption(btn, opt);
                    answerArea.appendChild(btn);
                });
            }
        } else if (round.type === 'multiple-choice' || round.type === 'image-identification') {
            q.options.forEach(opt => {
                const btn = document.createElement('button');
                btn.className = 'option-btn';
                btn.textContent = opt;
                btn.onclick = () => selectMCOption(btn, opt);
                answerArea.appendChild(btn);
            });
        } else if (round.type === 'fill-in-the-blank') {
            const label = document.createElement('label');
            label.textContent = 'Your answer';
            label.className = 'sr-only';
            label.setAttribute('for', 'fill-input');
            answerArea.appendChild(label);
            const input = document.createElement('input');
            input.type = 'text';
            input.id = 'fill-input';
            input.className = 'quiz-input';
            input.placeholder = 'Type your answer...';
            input.style.gridColumn = 'span 2';
            input.onkeydown = (e) => { if (e.key === 'Enter') { e.preventDefault(); submitAnswer(); } };
            answerArea.appendChild(input);
            submitBtn.classList.remove('hidden');
            submitBtn.style.background = '#59b0f7';
            submitBtn.style.color = '#fffdf1';
            setTimeout(() => input.focus(), 100);
        } else if (round.type === 'enumeration') {
            for (let i = 0; i < q.count; i++) {
                const label = document.createElement('label');
                label.textContent = `Answer ${i + 1}`;
                label.className = 'sr-only';
                label.setAttribute('for', `enum-input-${i}`);
                answerArea.appendChild(label);
                const input = document.createElement('input');
                input.type = 'text';
                input.id = `enum-input-${i}`;
                input.className = 'quiz-input';
                input.placeholder = `Answer ${i + 1}`;
                input.dataset.index = i;
                input.style.gridColumn = 'span 2';
                answerArea.appendChild(input);
            }
            submitBtn.classList.remove('hidden');
        }
        lucide.createIcons();
    }

    function selectMCOption(btn, option) {
        document.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        gameState.selectedAnswer = option;
        // Auto-submit after short delay for MC
        setTimeout(() => submitAnswer(), 300);
    }

    function submitAnswer() {
        const round = ROUNDS[gameState.currentRound];
        const q = round.questions[gameState.currentQuestion];
        let isCorrect = false;
        let correctText = '';

        if (round.type === 'multiple-choice' || round.type === 'image-identification') {
            if (!gameState.selectedAnswer) return;
            isCorrect = gameState.selectedAnswer === q.answer;
            correctText = q.answer;
            // Show correct/incorrect on options
            document.querySelectorAll('.option-btn').forEach(b => {
                b.onclick = null;
                if (b.textContent === q.answer) b.classList.add('correct');
                else if (b.classList.contains('selected') && !isCorrect) b.classList.add('incorrect');
            });
        } else if (round.type === 'fill-in-the-blank') {
            const input = document.getElementById('fill-input');
            const val = input.value.trim().toLowerCase();
            isCorrect = val === q.answer.toLowerCase();
            correctText = q.answer.charAt(0).toUpperCase() + q.answer.slice(1);
        } else if (round.type === 'enumeration') {
            const inputs = document.querySelectorAll('#answer-area input');
            const userAnswers = [...inputs].map(i => i.value.trim().toLowerCase());
            const correctAnswers = q.answers.map(a => a.toLowerCase());
            let matches = 0;
            userAnswers.forEach(ua => {
                if (correctAnswers.includes(ua)) matches++;
            });
            isCorrect = matches === q.count;
            correctText = q.answers.join(', ');
            // Partial credit
            if (matches > 0 && !isCorrect) {
                // Still count partial
            }
        }

        if (isCorrect) {
            const cp = gameState.players[gameState.currentPlayerIndex];
            gameState.scores[cp.name]++;
            gameState.roundScores[cp.name]++;
            fireConfetti();
        }

        setTimeout(() => showFeedback(isCorrect, correctText), round.type === 'multiple-choice' || round.type === 'image-identification' ? 600 : 200);
    }

    function showFeedback(isCorrect, correctText) {
        const templateId = isCorrect ? 'correct-feedback-screen-template' : 'incorrect-feedback-screen-template';
        const tpl = document.getElementById(templateId);
        container.innerHTML = '';
        container.appendChild(tpl.content.cloneNode(true));

        // Hide nav controls
        document.getElementById('nav-controls').classList.add('hidden');

        if (isCorrect) {
            const bgEl = document.querySelector('[data-template-id="correct-screen-bg"]');
            const heading = document.querySelector('[data-template-id="correct-heading"]');
            const caption = document.querySelector('[data-template-id="correct-caption"]');

            bgEl.style.background = 'var(--lime)';
            heading.textContent = 'Correct!';
            heading.style.color = 'var(--dark)';
            caption.textContent = 'Great job, keep it up!';
            caption.style.color = 'var(--dark)';
        } else {
            const bgEl = document.querySelector('[data-template-id="incorrect-screen-bg"]');
            const heading = document.querySelector('[data-template-id="incorrect-heading"]');
            const caption = document.querySelector('[data-template-id="incorrect-caption"]');
            const answerDisplay = document.querySelector('[data-template-id="incorrect-answer-display"]');

            bgEl.style.background = '#fb64d0';
            heading.textContent = 'Not Quite';
            heading.style.color = '#fffdf1';
            caption.textContent = correctText;
            caption.style.color = '#fffdf1';
            answerDisplay.textContent = correctText;
            answerDisplay.style.background = 'var(--lime)';
            answerDisplay.style.color = '#000000';
        }
    }

    function nextQuestion() {
        gameState.currentQuestion++;
        const round = ROUNDS[gameState.currentRound];

        if (gameState.mode === 'multiplayer') {
            const nextPlayerIdx = (gameState.currentPlayerIndex + 1) % gameState.players.length;
            if (nextPlayerIdx === 0 && gameState.currentQuestion < round.questions.length) {
                // All players answered this question, move to next
                gameState.currentPlayerIndex = 0;
                showQuestion();
            } else if (gameState.currentQuestion >= round.questions.length) {
                // Round done for this player, check if more players
                if (nextPlayerIdx !== 0) {
                    showTurnComplete(nextPlayerIdx);
                } else {
                    showRoundComplete();
                }
            } else {
                gameState.currentPlayerIndex = nextPlayerIdx;
                showTurnComplete(nextPlayerIdx);
            }
        } else {
            if (gameState.currentQuestion >= round.questions.length) {
                showRoundComplete();
            } else {
                showQuestion();
            }
        }
    }

    function resetQuiz() {
        gameState = {
            mode: 'solo',
            players: [],
            currentRound: 0,
            currentQuestion: 0,
            currentPlayerIndex: 0,
            scores: {},
            roundScores: {},
            selectedAnswer: null
        };
        document.getElementById('nav-controls').classList.add('hidden');
        showStartScreen();
    }

    function updateNavControls() {
        const navControls = document.getElementById('nav-controls');
        const backBtn = document.getElementById('back-btn');
        const nextBtn = document.getElementById('next-btn');
        const resetBtn = document.getElementById('reset-btn');
        const round = ROUNDS[gameState.currentRound];
        navControls.classList.remove('hidden');
        backBtn.disabled = gameState.currentQuestion === 0;
        nextBtn.disabled = gameState.currentQuestion >= round.questions.length - 1;
    }

    function goBack() {
        if (gameState.currentQuestion > 0) {
            gameState.currentQuestion--;
            showQuestion();
        }
    }

    function goNext() {
        const round = ROUNDS[gameState.currentRound];
        if (gameState.currentQuestion < round.questions.length - 1) {
            gameState.currentQuestion++;
            showQuestion();
        }
    }

    function showTurnComplete(nextIdx) {
        const cp = gameState.players[gameState.currentPlayerIndex];
        const np = gameState.players[nextIdx];

        const tpl = document.getElementById('turn-complete-template');
        container.innerHTML = '';
        container.appendChild(tpl.content.cloneNode(true));

        // Hide nav controls
        document.getElementById('nav-controls').classList.add('hidden');

        // Set heading and pass text (via data-template-id, will be populated from config)
        const heading = document.querySelector('[data-template-id="turn-complete-heading"]');
        const passText = document.querySelector('[data-template-id="turn-complete-pass-text"]');
        
        if (!heading.textContent || heading.textContent.trim() === '') {
            heading.textContent = 'Round Score';
        }
        if (!passText.textContent || passText.textContent.trim() === '') {
            passText.textContent = 'Pass the device to:';
        }

        // Set next player name
        document.getElementById('turn-next-player-name').textContent = np.name;

        // Set score pill with current player info
        const avatar = document.getElementById('turn-player-avatar');
        avatar.style.background = cp.color;
        avatar.textContent = cp.name.charAt(0).toUpperCase();

        document.getElementById('turn-player-name-pill').textContent = cp.name;
        document.getElementById('turn-player-round-score').textContent = `${gameState.roundScores[cp.name]}`;

        gameState.currentPlayerIndex = nextIdx;
    }

    function continueAfterTurn() {
        const round = ROUNDS[gameState.currentRound];
        if (gameState.currentQuestion >= round.questions.length) {
            showRoundComplete();
        } else {
            showQuestion();
        }
    }

    function showRoundComplete() {
        fireConfetti();
        const tpl = document.getElementById('round-complete-template');
        container.innerHTML = '';
        container.appendChild(tpl.content.cloneNode(true));

        // Hide nav controls
        document.getElementById('nav-controls').classList.add('hidden');

        const scoresContainer = document.getElementById('round-scores-container');
        const sorted = [...gameState.players].sort((a, b) => gameState.scores[b.name] - gameState.scores[a.name]);

        sorted.forEach((p) => {
            const row = document.createElement('div');
            row.style.cssText = `display: flex; align-items: center; justify-content: space-between; background: #fffdf1; border: 4px solid #000000; border-radius: 50px; padding: 12px 20px; gap: 12px; height: 96px;`;

            const av = document.createElement('div');
            av.className = 'avatar';
            av.style.background = p.color;
            av.style.width = '56px';
            av.style.height = '56px';
            av.style.flexShrink = '0';
            av.style.fontSize = '1.5rem';
            av.style.borderRadius = '50%';
            av.textContent = p.name.charAt(0).toUpperCase();

            const nameEl = document.createElement('span');
            nameEl.className = 'font-nunito';
            nameEl.style.cssText = `color: #000000; font-weight: 600; font-size: 24px; flex: 1;`;
            nameEl.textContent = p.name;

            const scoreEl = document.createElement('span');
            scoreEl.className = 'font-nunito';
            scoreEl.style.cssText = `color: var(--pink); font-weight: 700; font-size: 42px; padding-right: 24px;`;
            scoreEl.textContent = gameState.scores[p.name];

            row.appendChild(av);
            row.appendChild(nameEl);
            row.appendChild(scoreEl);
            scoresContainer.appendChild(row);
        });

        const nextBtn = document.getElementById('next-round-btn');
        if (gameState.currentRound >= ROUNDS.length - 1) {
            nextBtn.textContent = 'See Final Results';
            nextBtn.onclick = showGameOver;
        }
    }

    function nextRound() {
        gameState.currentRound++;
        if (gameState.currentRound >= ROUNDS.length) {
            showGameOver();
        } else {
            showRoundIntro();
        }
    }

    function showGameOver() {
        fireConfetti();
        setTimeout(fireConfetti, 800);

        const tpl = document.getElementById('game-over-template');
        container.innerHTML = '';
        container.appendChild(tpl.content.cloneNode(true));

        // Hide nav controls
        document.getElementById('nav-controls').classList.add('hidden');

        const sorted = [...gameState.players].sort((a, b) => gameState.scores[b.name] - gameState.scores[a.name]);
        const winner = sorted[0];
        const winnerText = document.getElementById('winner-text');
        
        // Check for draw in multiplayer mode
        const allScoresEqual = gameState.mode === 'multiplayer' && sorted.every(p => gameState.scores[p.name] === gameState.scores[winner.name]);
        
        if (gameState.mode === 'solo') {
            winnerText.textContent = `Final Score: ${gameState.scores[winner.name]} points`;
        } else if (allScoresEqual) {
            winnerText.textContent = `It's a draw! Everyone scored ${gameState.scores[winner.name]} points!`;
        } else {
            winnerText.textContent = `${winner.name} wins with ${gameState.scores[winner.name]} points!`;
        }

        const scoresContainer = document.getElementById('final-scores-container');
        sorted.forEach((p, idx) => {
            const row = document.createElement('div');
            row.style.cssText = `display: flex; align-items: center; justify-content: space-between; background: #fffdf1; border: 4px solid #000000; border-radius: 50px; padding: 12px 20px; gap: 12px; height: 96px;`;

            // Only show medal/rank if not a draw
            if (!allScoresEqual) {
                const medal = document.createElement('span');
                medal.style.cssText = `font-size: 32px; flex-shrink: 0;`;
                medal.textContent = idx === 0 ? '🥇' : idx === 1 ? '🥈' : idx === 2 ? '🥉' : `#${idx + 1}`;
                row.appendChild(medal);
            }

            const nameEl = document.createElement('span');
            nameEl.className = 'font-nunito';
            nameEl.style.cssText = `color: #000000; font-weight: 600; font-size: 24px; flex: 1;`;
            nameEl.textContent = p.name;

            const scoreEl = document.createElement('span');
            scoreEl.className = 'font-nunito';
            scoreEl.style.cssText = `color: var(--pink); font-weight: 700; font-size: 42px; padding-right: 24px;`;
            scoreEl.textContent = gameState.scores[p.name];

            row.appendChild(nameEl);
            row.appendChild(scoreEl);
            scoresContainer.appendChild(row);
        });
    }

    function playAgain() {
        // Same players, reset scores
        gameState.currentRound = 0;
        gameState.currentQuestion = 0;
        gameState.currentPlayerIndex = 0;
        gameState.players.forEach(p => gameState.scores[p.name] = 0);
        gameState.roundScores = {};
        showRoundIntro();
    }

    function newGame() {
        showStartScreen();
    }

    // ---- CONFETTI ----
    function fireConfetti() {
        const canvas = document.getElementById('confetti-canvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;

        const particles = [];
        const colors = ['#FF4FCB','#D7FF3F','#A7C7FF','#FFA94D','#A78BFA','#34D399','#FFF5D6'];

        for (let i = 0; i < 80; i++) {
            particles.push({
                x: Math.random() * canvas.width,
                y: -20 - Math.random() * 200,
                w: 6 + Math.random() * 8,
                h: 4 + Math.random() * 6,
                color: colors[Math.floor(Math.random() * colors.length)],
                vx: (Math.random() - 0.5) * 4,
                vy: 2 + Math.random() * 4,
                rotation: Math.random() * 360,
                rotSpeed: (Math.random() - 0.5) * 10,
                opacity: 1
            });
        }

        let frame = 0;
        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            let alive = false;
            particles.forEach(p => {
                if (p.opacity <= 0) return;
                alive = true;
                p.x += p.vx;
                p.y += p.vy;
                p.vy += 0.08;
                p.rotation += p.rotSpeed;
                if (p.y > canvas.height - 50) p.opacity -= 0.03;

                ctx.save();
                ctx.translate(p.x, p.y);
                ctx.rotate(p.rotation * Math.PI / 180);
                ctx.globalAlpha = Math.max(0, p.opacity);
                ctx.fillStyle = p.color;
                ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
                ctx.restore();
            });
            frame++;
            if (alive && frame < 180) requestAnimationFrame(animate);
            else ctx.clearRect(0, 0, canvas.width, canvas.height);
        }
        animate();
    }

    // ---- INIT ----
    document.addEventListener('DOMContentLoaded', () => {
        showStartScreen();
        lucide.createIcons();
    });

    window.addEventListener('resize', () => {
        const canvas = document.getElementById('confetti-canvas');
        if (canvas) {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
    });
