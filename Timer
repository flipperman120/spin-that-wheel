    </div><!-- Control buttons -->
    <div class="flex gap-4 z-10 relative">
     <button id="start-btn" data-template-id="start-button" class="canva-button btn-primary px-8 py-3 rounded-full font-semibold transition-all" style="background: rgb(255, 255, 255); color: rgb(55, 46, 24); font-weight: 600; font-size: 16px;">Start</button> <button id="reset-btn" data-template-id="reset-button" class="canva-button btn-secondary px-8 py-3 rounded-full font-semibold transition-all" style="background: rgba(255, 255, 255, 0.2); color: rgb(255, 255, 255); font-weight: 600; font-size: 16px;">Reset</button>
