  <script>
        lucide.createIcons();

        const TOTAL_SECONDS = 15 * 60;
        let remainingSeconds = TOTAL_SECONDS;
        let selectedDuration = TOTAL_SECONDS;
        let timerInterval = null;
        let isRunning = false;
        let hasStarted = false;

        const timerDisplay = document.getElementById('timer-display');
        const timerWrapper = document.getElementById('timer-wrapper');
        const startBtn = document.getElementById('start-btn');
        const resetBtn = document.getElementById('reset-btn');
        const bgEl = document.querySelector('.meditation-bg');
        const durationSelector = document.getElementById('duration-selector');
        const durationBtns = document.querySelectorAll('.duration-btn');

        // Initialize duration buttons
        durationBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const minutes = parseInt(btn.dataset.minutes, 10);
                selectedDuration = minutes * 60;
                remainingSeconds = selectedDuration;
                
                // Update active state
                durationBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                
                updateDisplay();
            });
        });

        // Start button handler
        startBtn.addEventListener('click', () => {
            if (!isRunning) {
                startTimerSession();
            } else {
                pauseTimer();
            }
        });

        // Reset button handler
        resetBtn.addEventListener('click', () => {
            reset();
        });

        // Set 15m as default active
        document.querySelector('[data-minutes="15"]').classList.add('active');

        updateDisplay();

        function formatTime(seconds) {
            const m = Math.floor(seconds / 60);
            const s = seconds % 60;
            return `${m}:${s.toString().padStart(2, '0')}`;
        }

        function updateDisplay() {
            timerDisplay.textContent = formatTime(remainingSeconds);

            // Timer display stays white throughout countdown
            timerDisplay.style.color = '#ffffff';
        }

        function playCompletionTone() {
            try {
                const ctx = new (window.AudioContext || window.webkitAudioContext)();
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();

                osc.connect(gain);
                gain.connect(ctx.destination);

                osc.type = 'sine';
                osc.frequency.setValueAtTime(528, ctx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(396, ctx.currentTime + 1.2);

                gain.gain.setValueAtTime(0.3, ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 1.5);

                osc.start(ctx.currentTime);
                osc.stop(ctx.currentTime + 1.5);
            } catch (e) {
                // Audio not supported — silent fallback
            }
        }

        function onComplete() {
            isRunning = false;
            clearInterval(timerInterval);
            timerInterval = null;

            timerWrapper.classList.remove('pulse-active');
            timerWrapper.classList.add('pulse-complete');

            durationSelector.style.opacity = '1';
            durationSelector.style.pointerEvents = 'auto';

            playCompletionTone();
        }

        function tick() {
            if (remainingSeconds <= 0) {
                onComplete();
                return;
            }
            remainingSeconds--;
            updateDisplay();
            if (remainingSeconds <= 0) {
                onComplete();
            }
        }

        function startTimerSession() {
            if (remainingSeconds <= 0) return;

            isRunning = true;
            hasStarted = true;
            timerWrapper.classList.add('pulse-active');
            timerWrapper.classList.add('timer-centered');
            durationSelector.style.opacity = '0';
            durationSelector.style.pointerEvents = 'none';
            
            // Update button text
            startBtn.textContent = 'Pause';

            timerInterval = setInterval(tick, 1000);
        }

        function pauseTimer() {
            // Pause
            isRunning = false;
            clearInterval(timerInterval);
            timerInterval = null;
            timerWrapper.classList.remove('pulse-active');
            durationSelector.style.opacity = '1';
            durationSelector.style.pointerEvents = 'auto';
            
            // Update button text
            startBtn.textContent = 'Resume';
        }

        function reset() {
            isRunning = false;
            hasStarted = false;
            clearInterval(timerInterval);
            timerInterval = null;

            remainingSeconds = selectedDuration;

            timerWrapper.classList.remove('pulse-active', 'pulse-complete', 'timer-centered');

            timerDisplay.style.color = '';

            durationSelector.style.opacity = '1';
            durationSelector.style.pointerEvents = 'auto';
            
            // Reset button text
            startBtn.textContent = 'Start';

            updateDisplay();
        }

        updateDisplay();
    </script>
