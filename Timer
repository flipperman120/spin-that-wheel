  <title>Meditation Timer</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&amp;display=swap" rel="stylesheet">
  <style>


        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            overflow: hidden;
        }

        .meditation-bg {
            background: #ebbb45;
            min-height: calc(100 * min(var(--vh, 1vh), 1vh));
            width: 100%;
        }

        .timer-text {
            font-variant-numeric: tabular-nums;
            text-shadow: 0 4px 30px rgba(0, 0, 0, 0.15);
            transition: color 1.5s ease;
        }

        .pulse-active {
            animation: timerPulse 2s ease-in-out infinite;
        }

        .pulse-complete {
            animation: timerPulseRapid 0.6s ease-in-out infinite;
        }

        @keyframes timerPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        @keyframes timerPulseRapid {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.08); }
        }

        .btn-primary {
            backdrop-filter: blur(12px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            text-align: center;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .btn-secondary {
            backdrop-filter: blur(12px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            text-align: center;
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.35);
            transform: translateY(-2px);
        }

        .btn-secondary:active {
            transform: translateY(0);
        }

        .btn-secondary:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            transform: none;
        }

        .btn-secondary:disabled:hover {
            background: rgba(255, 255, 255, 0.2);
            transform: none;
        }

        .session-label {
            letter-spacing: 0.25em;
            text-transform: uppercase;
        }

        .duration-btn {
            background: rgba(255, 255, 255, 0.25);
            color: #372e18;
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .duration-btn:hover {
            background: rgba(255, 255, 255, 0.35);
            transform: translateY(-2px);
        }

        .duration-btn:active {
            transform: translateY(0);
        }

        .duration-btn.active {
            background: rgba(255, 255, 255, 0.5);
            font-weight: 700;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }

        /* Decorative ring behind timer */
        .timer-ring {
            position: absolute;
            width: 352px;
            height: 352px;
            border-radius: 50%;
            border: 2px solid rgba(255, 255, 255, 0.08);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none;
        }

        .timer-ring-outer {
            width: 418px;
            height: 418px;
            border-color: rgba(255, 255, 255, 0.04);
        }

        /* Timer wrapper transitions */
        #timer-wrapper {
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        #timer-wrapper.timer-centered {
            position: relative;
            margin-bottom: 0;
        }

        @media (max-width: 640px) {
            .timer-ring { width: 264px; height: 264px; }
            .timer-ring-outer { width: 319px; height: 319px; }
        }
    </style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
  <script src="/_sdk/resizing_sdk.js" type="text/javascript"></script>
 </head>
 <body data-template-id="__page-root" class="w-full" style="background: rgb(235, 187, 69);">
  <main class="meditation-bg flex flex-col items-center justify-center relative py-8 sm:py-12" role="main">
   <!-- Decorative rings -->
   <div class="timer-ring" aria-hidden="true"></div>
   <div class="timer-ring timer-ring-outer" aria-hidden="true"></div><!-- Session label -->
   <p data-template-id="session-label" class="canva-text session-label text-sm mb-8 relative z-10" style="color: rgba(255, 255, 255, 0.7); font-weight: 700; font-style: normal; font-size: 18px;">The Clock is Ticking</p><!-- Timer display -->
   <div class="relative z-10 flex flex-col items-center">
    <div id="timer-wrapper" class="mb-12">
     <h1 data-template-id="timer-display" id="timer-display" class="canva-text timer-text text-[106px] sm:text-[132px] md:text-[158px] font-extrabold leading-none select-none bg-transparent border-none p-0" style="color: rgb(255, 255, 255); font-weight: 900; font-style: normal; font-size: 174px;">15:00</h1>
