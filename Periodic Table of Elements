    const catClass={alkali:"cat-alkali",alkaline:"cat-alkaline",transition:"cat-transition","post-transition":"cat-post-transition",metalloid:"cat-metalloid",nonmetal:"cat-nonmetal",halogen:"cat-halogen",noble:"cat-noble",lanthanide:"cat-lanthanide",actinide:"cat-actinide",unknown:"cat-unknown"};
