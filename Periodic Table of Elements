    function showDetail(el,cell){
        if(selectedEl===cell){
            closeDetail();return;
        }
        if(selectedEl) selectedEl.classList.remove("selected");
        selectedEl=cell;
        cell.classList.add("selected");

        panel.className=`detail-panel open rounded-xl p-6 mx-auto max-w-2xl ${catBg[el.cat]}`;
        content.innerHTML=`
