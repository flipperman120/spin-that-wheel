    const catNames={alkali:"Alkali Metals",alkaline:"Alkaline Earth",transition:"Transition Metals","post-transition":"Post-Transition",metalloid:"Metalloids",nonmetal:"Nonmetals",halogen:"Halogens",noble:"Noble Gases",lanthanide:"Lanthanides",actinide:"Actinides",unknown:"Unknown"};

    let selectedEl=null;
    const panel=document.getElementById("detail-panel");
    const content=document.getElementById("detail-content");

    function makeCell(el){
        const d=document.createElement("div");
        d.className=`el-cell ${catClass[el.cat]}`;
        d.setAttribute("role","button");
        d.setAttribute("tabindex","0");
        d.setAttribute("aria-label",`${el.name}, element ${el.z}`);
        d.innerHTML=`<span class="num">${el.z}</span><span class="sym">${el.sym}</span><span class="nm">${el.name}</span>`;
        d.addEventListener("click",()=>showDetail(el,d));
        d.addEventListener("keydown",e=>{if(e.key==="Enter"||e.key===" "){e.preventDefault();showDetail(el,d);}});
        return d;
    }

    // Build main grid (rows 1-7, cols 1-18) with placeholders for lanthanide/actinide markers
    const grid=document.getElementById("periodic-table");
    const mainEls=elements.filter(e=>e.r>=1&&e.r<=7);
    const cells=Array.from({length:7},()=>Array(18).fill(null));
    mainEls.forEach(e=>{cells[e.r-1][e.c-1]=e;});

    // Place lanthanide/actinide placeholder markers at row 6 col 3 and row 7 col 3
    for(let r=0;r<7;r++){
        for(let c=0;c<18;c++){
            const el=cells[r][c];
            if(r===5&&c===2){
                const m=document.createElement("div");
                m.className="el-cell cat-lanthanide";
                m.style.fontSize="9px";m.style.opacity="0.7";m.style.cursor="default";
                m.innerHTML="<span class='sym' style='font-size:11px'>57-71</span>";
                grid.appendChild(m);
            } else if(r===6&&c===2){
                const m=document.createElement("div");
                m.className="el-cell cat-actinide";
                m.style.fontSize="9px";m.style.opacity="0.7";m.style.cursor="default";
                m.innerHTML="<span class='sym' style='font-size:11px'>89-103</span>";
                grid.appendChild(m);
            } else if(el){
                grid.appendChild(makeCell(el));
            } else {
                const sp=document.createElement("div");
                sp.style.width="58px";sp.style.height="62px";
                grid.appendChild(sp);
            }
        }
    }

    // Lanthanides & Actinides rows
    const lanRow=document.getElementById("lanthanides-row");
    const actRow=document.getElementById("actinides-row");
    const lans=elements.filter(e=>e.r===9).sort((a,b)=>a.c-b.c);
    const acts=elements.filter(e=>e.r===10).sort((a,b)=>a.c-b.c);

    // Pad with 2 empty spacers for alignment (cols 1-2 empty)
    for(let i=0;i<2;i++){const s=document.createElement("div");s.style.width="58px";s.style.height="62px";lanRow.appendChild(s);}
    lans.forEach(e=>lanRow.appendChild(makeCell(e)));
    for(let i=0;i<2;i++){const s=document.createElement("div");s.style.width="58px";s.style.height="62px";actRow.appendChild(s);}
    acts.forEach(e=>actRow.appendChild(makeCell(e)));

    // Legend
    const legend=document.getElementById("legend");
