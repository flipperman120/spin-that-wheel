   </div>
  </footer>
  <script src="/_sdk/editing_sdk.js"></script>
  <script>
(function(){
  const $=id=>document.getElementById(id);
  const propInput=$('propertyValue'),costInput=$('paintingCost');
  const incSlider=$('valueIncrease'),yearSlider=$('years');
  const incDisp=$('increaseDisplay'),yearDisp=$('yearsDisplay');
  const canvas=$('chart'),ctx=canvas.getContext('2d');
  let animBars=[],animId=null;
  function parseNum(s){return parseInt(s.replace(/[^0-9]/g,''),10)||0;}
  function fmt(n){return n.toLocaleString('en-US');}
  function fmtDollar(n){return '$'+fmt(Math.round(n));}
  function formatOnBlur(input){
    input.addEventListener('blur',()=>{const v=parseNum(input.value);if(v)input.value=fmt(v);});
    input.addEventListener('focus',()=>{input.value=input.value.replace(/,/g,'');});
  }
  formatOnBlur(propInput);formatOnBlur(costInput);
  function calc(){
    const pv=parseNum(propInput.value),pc=parseNum(costInput.value);
    const pct=parseInt(incSlider.value),yrs=parseInt(yearSlider.value);
    incDisp.textContent=pct+'%';yearDisp.textContent=yrs;
    const increase=pv*(pct/100),net=increase-pc,roi=pc?((net/pc)*100):0;
    $('statRoi').textContent=roi.toFixed(0)+'%';
    $('statIncrease').textContent=fmtDollar(increase);
    $('statNet').textContent=fmtDollar(net);
    const targets=[];
    for(let i=1;i<=yrs;i++)targets.push(pv*Math.pow(1+pct/100,i));
    animateBars(targets,pv,yrs);
  }
  function animateBars(targets,baseline,yrs){
    if(!animBars.length||animBars.length!==targets.length)animBars=targets.map(()=>0);
    const speed=.12;
    if(animId)cancelAnimationFrame(animId);
    function step(){
      let done=true;
      for(let i=0;i<targets.length;i++){
        animBars[i]+=(targets[i]-animBars[i])*speed;
        if(Math.abs(targets[i]-animBars[i])>1)done=false;else animBars[i]=targets[i];
      }
      drawChart(animBars,baseline,yrs);
      if(!done)animId=requestAnimationFrame(step);else animId=null;
    }
    step();
  }
  function drawChart(bars,baseline){
    const dpr=window.devicePixelRatio||1;
    const w=canvas.clientWidth,h=canvas.clientHeight;
    canvas.width=w*dpr;canvas.height=h*dpr;
    ctx.setTransform(dpr,0,0,dpr,0,0);ctx.clearRect(0,0,w,h);
    const pad={t:20,r:16,b:32,l:60};
    const cw=w-pad.l-pad.r,ch=h-pad.t-pad.b;
    const maxVal=Math.max(...bars)*1.12||1,minVal=baseline*.95,range=maxVal-minVal;
    const barW=cw/bars.length*.6,gap=cw/bars.length*.4;
    ctx.fillStyle='#4a5a4e';ctx.font='11px Inter';ctx.textAlign='right';
    for(let i=0;i<=4;i++){
      const v=minVal+range*(i/4),y=pad.t+ch-ch*(i/4);
      ctx.fillText('$'+Math.round(v/1000)+'k',pad.l-8,y+4);
      ctx.strokeStyle='#e0e8e2';ctx.lineWidth=.5;
      ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(w-pad.r,y);ctx.stroke();
    }
    const blY=pad.t+ch-ch*((baseline-minVal)/range);
    ctx.setLineDash([5,4]);ctx.strokeStyle='#999';ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(pad.l,blY);ctx.lineTo(w-pad.r,blY);ctx.stroke();
    ctx.setLineDash([]);
    bars.forEach((v,i)=>{
      const x=pad.l+i*(barW+gap)+gap/2;
      const barH=ch*((v-minVal)/range);
      const y=pad.t+ch-barH;
      const grad=ctx.createLinearGradient(x,y,x,pad.t+ch);
      grad.addColorStop(0,'rgba(66,156,170,1)');grad.addColorStop(1,'rgba(71,134,105,1)');
      ctx.fillStyle=grad;
      ctx.beginPath();ctx.roundRect(x,y,barW,barH,[6,6,0,0]);ctx.fill();
      ctx.fillStyle='#1a1a1a';ctx.font='bold 11px Inter';ctx.textAlign='center';
      ctx.fillText('Yr '+(i+1),x+barW/2,pad.t+ch+18);
      ctx.fillStyle='#47876b';ctx.font='bold 10px Inter';
      ctx.fillText('$'+Math.round(v/1000)+'k',x+barW/2,y-6);
    });
  }
  [propInput,costInput].forEach(el=>el.addEventListener('input',calc));
  [incSlider,yearSlider].forEach(el=>el.addEventListener('input',calc));
  calc();
})();
  </script>
