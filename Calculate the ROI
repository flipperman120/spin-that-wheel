     <h1 data-template-id="hero-heading" class="canva-text" style="font-weight: 400; line-height: 1.05; color: rgb(255, 255, 255); font-style: normal; font-size: 111px;">Calculate
the ROI</h1>
     <p data-template-id="hero-subtitle" class="canva-text mt-4" style="color: rgb(255, 255, 255); font-weight: 400; font-style: normal; font-size: 23px;">See how your project increases in value over time</p>
    </div>
    <div class="h-64 md:h-auto">
     <img data-template-id="hero-image" class="canva-image w-full h-full object-cover" loading="lazy" src="canva://MAFq19JCUJo/1" alt="Geometric Fintech Background">
    </div>
   </div>
  </header><!-- Calculator Section -->
  <main data-template-id="calc-section" class="w-full canva-section" style="background: rgb(232, 243, 238);">
   <div class="max-w-[1400px] mx-auto px-8 md:px-16 pt-16 pb-14 mb-8">
    <div class="mb-8">
     <h2 data-template-id="calc-heading" class="canva-text" style="color: rgb(71, 135, 107); font-weight: 400; font-style: normal; font-size: 42px;">See how a project's value changes over time</h2>
     <p data-template-id="calc-description" class="canva-text mt-2" style="color: rgb(26, 26, 26); font-weight: 400; font-style: normal; font-size: 18px;">Add your project details below</p>
    </div>
    <div class="grid md:grid-cols-2 gap-8">
     <div class="space-y-5">
      <div>
       <label data-template-id="label-property-value" class="canva-text block mb-1 font-medium" for="propertyValue" style="color: rgb(26, 26, 26); font-weight: 500; font-style: normal; font-size: 14px;">Value ($)</label> <input id="propertyValue" type="text" class="num-input" value="350,000">
      </div>
      <div>
       <label data-template-id="label-painting-cost" class="canva-text block mb-1 font-medium" for="paintingCost" style="color: rgb(26, 26, 26); font-weight: 500; font-style: normal; font-size: 14px;">Cost ($)</label> <input id="paintingCost" type="text" class="num-input" value="5,000">
      </div>
      <div>
       <label data-template-id="label-value-increase" class="canva-text block mb-1 font-medium" for="valueIncrease" style="color: rgb(26, 26, 26); font-weight: 500; font-style: normal; font-size: 14px;">Value Increase (%)</label>
       <div class="flex items-center gap-3">
        <input id="valueIncrease" type="range" min="1" max="15" value="5" class="flex-1"> <span id="increaseDisplay" class="font-bold text-lg" style="color:#47876b;min-width:42px;text-align:right">5%</span>
       </div>
      </div>
      <div>
       <label data-template-id="label-years" class="canva-text block mb-1 font-medium" for="years" style="color: rgb(26, 26, 26); font-weight: 500; font-style: normal; font-size: 14px;">Years to Project</label>
       <div class="flex items-center gap-3">
        <input id="years" type="range" min="1" max="10" value="5" class="flex-1"> <span id="yearsDisplay" class="font-bold text-lg" style="color:#47876b;min-width:42px;text-align:right">5</span>
       </div>
      </div>
      <div class="pt-4">
       <h3 data-template-id="results-heading" class="canva-text font-bold mb-3" style="color: rgb(71, 135, 107); font-weight: 400; font-style: normal; font-size: 26px;">Your Projected ROI</h3>
       <div class="grid grid-cols-3 gap-3">
        <div class="stat-card">
         <p data-template-id="stat-label-roi" class="canva-text text-sm mb-1" style="color: rgb(74, 90, 78); font-weight: 500; font-style: normal; font-size: 16px;">Total ROI</p>
